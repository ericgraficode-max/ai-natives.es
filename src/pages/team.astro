---
import Layout from '../layouts/Layout.astro';

const team = [
  {
    name: 'Eric Martinez Solis',
    role: 'Co‑founder · Product & Design',
    bio: 'Design Director specializing in product design, research, and experimentation. Eric has led design and research for €100M+ platforms across Europe, including Flaconi, KFZteile24, Vodafone, eBay, and Dunnhumby.',
    experience: 'led 100M+ platforms',
    avatar: '/Eric_Martinez.jpg'
  },
  {
    name: 'Victor',
    role: 'Co‑founder · AI‑native CTO',
    bio: 'Entrepreneurial CTO comfortable bridging modern front‑end, cloud, and AI‑driven workflows. He ensures that every idea we design can be implemented cleanly and performantly.',
    experience: '10+ years scaling intl. products',
    avatar: '/Victor_Arias.jpg' 
  },
  {
    name: 'Belinda',
    role: 'SEO & Organic Growth',
    bio: 'Focuses on organic visibility, technical SEO, and content strategy. She connects what people actually search for with how your product is presented.',
    experience: 'Technical SEO expert',
    avatar: '/Belinda_Martinez.jpg'
  },
  {
    name: 'Katja',
    role: 'SEA & Performance Marketing',
    bio: 'Leads paid search and performance marketing with a strong brand sensibility. She treats SEA as part of a broader system aligned with UX and analytics.',
    experience: 'Performance system architect',
    avatar: '/Katja_Kicken.jpg'
  }
];
---

<Layout
  title="Team | Hound | ai-native"
  description="A senior product squad with experience from Europe's biggest platforms, now helping Spanish brands grow."
>
  <section class="section-team relative px-6 pb-32 pt-24 md:pt-32 overflow-hidden">
     <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-6xl h-px bg-gradient-to-r from-transparent via-zinc-800 to-transparent"></div>
     
    <div class="team-header mx-auto max-w-4xl text-center mb-24" data-animation="fade-up">
      <p class="mb-4 text-xs font-semibold uppercase tracking-[0.3em] text-cyan-300">
        The Core Squad
      </p>
      <h1 class="mb-6 text-5xl font-bold tracking-tight md:text-7xl">
        Senior brains. <br/><span class="text-zinc-500">Zero overhead.</span>
      </h1>
      <p class="mx-auto max-w-2xl text-lg text-zinc-400">
        We’re not a traditional agency. We’re a senior-only team that integrates directly into your business to ship high-impact work.
      </p>
    </div>

    <div class="team-grid mx-auto grid max-w-6xl gap-12 md:grid-cols-2">
      {team.map((member, i) => (
        <article class="team-card group relative flex flex-col gap-8 rounded-3xl border border-zinc-800 bg-zinc-900/40 p-8 transition-all hover:border-cyan-400/30" data-animation="fade-up">
           <div class="flex flex-col sm:flex-row gap-8 items-start">
              <div class="member-avatar relative shrink-0">
                 <!-- AI Portrait Placeholder/Simulation -->
                 <div class="h-32 w-32 overflow-hidden rounded-2xl bg-zinc-800 relative group-hover:scale-105 transition-transform duration-500">
                    <img src={member.avatar} alt={member.name} class="h-full w-full object-cover grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all" />
                    <div class="absolute inset-0 ring-1 ring-inset ring-white/10 rounded-2xl"></div>
                 </div>
                 <div class="member-rank absolute -bottom-2 -right-2 h-8 w-8 rounded-lg bg-cyan-400 flex items-center justify-center text-zinc-950 font-bold text-xs">
                    {i + 1}
                 </div>
              </div>
              
              <div class="member-info flex-1">
                 <p class="mb-1 text-xs font-bold uppercase tracking-widest text-cyan-400">{member.role}</p>
                 <h2 class="mb-4 text-3xl font-bold text-zinc-100">{member.name}</h2>
                 <p class="text-sm text-zinc-400 leading-relaxed mb-6">
                    {member.bio}
                 </p>
                 <div class="member-experience inline-flex items-center gap-2 rounded-full bg-zinc-800/50 px-3 py-1 text-[10px] font-bold text-zinc-300 border border-zinc-700">
                    <span class="h-1.5 w-1.5 rounded-full bg-green-500"></span>
                    {member.experience}
                 </div>
              </div>
           </div>
        </article>
      ))}
    </div>

    <div class="team-why-senior mx-auto mt-32 max-w-4xl text-center rounded-3xl border border-zinc-800 bg-gradient-to-b from-zinc-900 to-zinc-950 p-12" data-animation="fade-up">
      <h2 class="mb-4 text-3xl font-bold">Why senior-only?</h2>
      <p class="mb-8 text-zinc-400">
        In traditional agencies, you meet the partners during the pitch and work with juniors during the project. 
        At Hound | ai-native, the people on this page are the ones actually doing the research, writing the code, and optimizing your ads. 
        Better quality, faster shipping, zero friction.
      </p>
      <a
        href="/contact"
        class="btn-primary inline-flex items-center justify-center rounded-xl bg-cyan-400 px-10 py-4 text-sm font-bold text-zinc-950 transition-all hover:bg-cyan-300 hover:scale-105"
      >
        Meet us on a call
      </a>
    </div>
  </section>
</Layout>
