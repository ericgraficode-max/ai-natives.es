---
import Layout from '../layouts/Layout.astro';

const team = [
  {
    name: 'Eric Martinez Solis',
    role: 'Co‑founder · Product & Design',
    bio: 'Design Director mit Fokus auf Produktdesign, Research und Experimentation. Eric hat Design- und Research-Teams für Plattformen mit über 100 Mio. € Umsatz geleitet, darunter flaconi, kfzteile24, Vodafone und eBay.',
    experience: 'Leitete 100M€+ Plattformen',
    avatar: 'https://unavatar.io/twitter/ericsolis'
  },
  {
    name: 'Victor',
    role: 'Co‑founder · AI‑native CTO',
    bio: 'Unternehmerischer CTO, der die Brücke zwischen modernem Frontend, Cloud-Infrastruktur und KI-gestützten Workflows schlägt. Er stellt sicher, dass jede Design-Idee sauber und performant umgesetzt wird.',
    experience: '10+ Jahre intl. Produkt-Skalierung',
    avatar: 'https://unavatar.io/github/vgm' 
  },
  {
    name: 'Belinda',
    role: 'SEO & Organic Growth',
    bio: 'Konzentriert sich auf organische Sichtbarkeit, technisches SEO und Content-Strategie. Sie verbindet das Suchverhalten der Nutzer mit der optimalen Präsentation Ihres Produkts.',
    experience: 'Expertin für technisches SEO',
    avatar: 'https://unavatar.io/microlink/belinda.com'
  },
  {
    name: 'Katja',
    role: 'SEA & Performance Marketing',
    bio: 'Leitet Paid Search und Performance Marketing mit einem starken Gespür für Marke und Kreation. Sie betrachtet SEA als Teil eines Gesamtsystems abgestimmt auf UX und Analytics.',
    experience: 'Performance-System Architektin',
    avatar: 'https://unavatar.io/microlink/katja.com'
  }
];
---

<Layout
  lang="de"
  title="Team | AI‑Native.es"
  description="Ein Senior-Produktteam mit Erfahrung von den größten europäischen Plattformen, das jetzt spanischen Marken beim Wachsen hilft."
>
  <section class="relative px-6 pb-32 pt-24 md:pt-32 overflow-hidden">
     <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full max-w-6xl h-px bg-gradient-to-r from-transparent via-zinc-800 to-transparent"></div>
     
    <div class="mx-auto max-w-4xl text-center mb-24" data-animation="fade-up">
      <p class="mb-4 text-xs font-semibold uppercase tracking-[0.3em] text-cyan-300">
        Das Kernteam
      </p>
      <h1 class="mb-6 text-5xl font-bold tracking-tight md:text-7xl">
        Senior Köpfe. <br/><span class="text-zinc-500">Ohne Overhead.</span>
      </h1>
      <p class="mx-auto max-w-2xl text-lg text-zinc-400">
        Wir sind keine klassische Agentur. Wir sind ein reines Senior-Team, das sich direkt in Ihr Business integriert, um High-Impact-Work zu liefern.
      </p>
    </div>

    <div class="mx-auto grid max-w-6xl gap-12 md:grid-cols-2">
      {team.map((member, i) => (
        <article class="group relative flex flex-col gap-8 rounded-3xl border border-zinc-800 bg-zinc-900/40 p-8 transition-all hover:border-cyan-400/30" data-animation="fade-up">
           <div class="flex flex-col sm:flex-row gap-8 items-start">
              <div class="relative shrink-0">
                 <div class="h-32 w-32 overflow-hidden rounded-2xl bg-zinc-800 relative group-hover:scale-105 transition-transform duration-500">
                    <img src={member.avatar} alt={member.name} class="h-full w-full object-cover grayscale opacity-80 group-hover:grayscale-0 group-hover:opacity-100 transition-all" />
                    <div class="absolute inset-0 ring-1 ring-inset ring-white/10 rounded-2xl"></div>
                 </div>
                 <div class="absolute -bottom-2 -right-2 h-8 w-8 rounded-lg bg-cyan-400 flex items-center justify-center text-zinc-950 font-bold text-xs">
                    {i + 1}
                 </div>
              </div>
              
              <div class="flex-1">
                 <p class="mb-1 text-xs font-bold uppercase tracking-widest text-cyan-400">{member.role}</p>
                 <h2 class="mb-4 text-3xl font-bold text-zinc-100">{member.name}</h2>
                 <p class="text-sm text-zinc-400 leading-relaxed mb-6">
                    {member.bio}
                 </p>
                 <div class="inline-flex items-center gap-2 rounded-full bg-zinc-800/50 px-3 py-1 text-[10px] font-bold text-zinc-300 border border-zinc-700">
                    <span class="h-1.5 w-1.5 rounded-full bg-green-500"></span>
                    {member.experience}
                 </div>
              </div>
           </div>
        </article>
      ))}
    </div>

    <div class="mx-auto mt-32 max-w-4xl text-center rounded-3xl border border-zinc-800 bg-gradient-to-b from-zinc-900 to-zinc-950 p-12" data-animation="fade-up">
      <h2 class="mb-4 text-3xl font-bold">Warum nur Senior-Level?</h2>
      <p class="mb-8 text-zinc-400">
        In klassischen Agenturen lernen Sie die Partner beim Pitch kennen und arbeiten im Projekt mit Junioren. 
        Bei AI‑Native.es sind die Personen auf dieser Seite diejenigen, die tatsächlich recherchieren, den Code schreiben und Ihre Anzeigen optimieren. 
        Bessere Qualität, schnellere Umsetzung, null Reibungsverlust.
      </p>
      <a
        href="/de/contact"
        class="inline-flex items-center justify-center rounded-xl bg-cyan-400 px-10 py-4 text-sm font-bold text-zinc-950 transition-all hover:bg-cyan-300 hover:scale-105"
      >
        Lernen Sie uns kennen
      </a>
    </div>
  </section>
</Layout>
