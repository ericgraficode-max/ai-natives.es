---
import Layout from '../../../layouts/Layout.astro';
import { ChevronRight } from '../../../components/FeatherIcons.ts';
---

<Layout
  lang="de"
  title="Europäische Barrierefreiheits-Compliance & Audits | Hound | ai-native"
  description="Pragmatische Accessibility-Audits und Roadmaps für digitale Produkte. Sichern Sie die Einhaltung des European Accessibility Act (EAA) und der WCAG-Standards."
>
  <!-- Hero Section -->
  <section class="service-hero-section relative overflow-hidden px-6 pb-32 pt-24 md:pt-32">
    <div class="absolute inset-0 -z-20 mask-gradient-to-right">
      <img src="/1_conversion_optimization_.webp" alt="" class="h-full w-full object-cover" />
    </div>
    <div class="absolute inset-0 -z-10 opacity-20">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-cyan-500/20 rounded-full blur-3xl animate-pulse" />
      <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-violet-500/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s" />
    </div>

    <div class="mx-auto max-w-5xl text-center" data-animation="fade-up">
      <p class="mb-4 text-xs font-semibold uppercase tracking-[0.3em] text-cyan-300">
        Inklusion & Compliance
      </p>
      <h1 class="mb-6 text-4xl font-bold tracking-tight md:text-6xl lg:text-7xl">
        Bauen für alle. <span class="bg-gradient-to-r from-cyan-300 to-violet-400 bg-clip-text text-transparent">Konform bleiben.</span>
      </h1>
      <p class="mx-auto mb-10 max-w-3xl text-lg text-zinc-400 md:text-xl">
        Der European Accessibility Act (EAA) kommt. Wir helfen Produkt-Teams, die WCAG-Standards 
        mit pragmatischen Audits zu meistern, die rechtliche Anforderungen mit Produkt-Geschwindigkeit vereinen.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/de/contact"
          class="rounded-lg bg-cyan-400 px-8 py-4 font-semibold text-zinc-950 transition-colors hover:bg-cyan-300"
        >
          Barrierefreiheits-Audit buchen
        </a>
        <a
          href="#framework"
          class="rounded-lg border border-zinc-700 px-8 py-4 text-zinc-300 transition-colors hover:border-cyan-400/50 hover:text-cyan-300"
        >
          Unser Framework
        </a>
      </div>
    </div>
  </section>

  <!-- Value Proposition -->
  <section class="border-y border-zinc-900 bg-zinc-950/50 px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-12 lg:grid-cols-2 items-center">
        <div data-animation="fade-up">
          <h2 class="mb-6 text-3xl font-bold md:text-4xl">Compliance ist mehr als eine rechtliche Hürde</h2>
          <p class="mb-6 text-zinc-400">
            Inspiriert von Branchenführern wie Level Access glauben wir, dass Barrierefreiheit ein Wettbewerbsvorteil ist. 
            Ein barrierefreies Produkt erreicht ein breiteres Publikum, performt besser in SEO und schützt Ihre Marke 
            vor teuren Klagen und Bußgeldern.
          </p>
          <ul class="space-y-4">
            {[
              "Einhaltung der WCAG 2.1 / 2.2 AA Standards",
              "Konformität mit dem European Accessibility Act (EAA) / BFSG",
              "VPAT-Erstellung für Enterprise- & Behördenaufträge",
              "Verbesserte UX für alle Nutzer, nicht nur für Menschen mit Behinderungen"
            ].map(item => (
              <li class="flex items-center gap-3 text-zinc-300">
                <span class="flex h-5 w-5 items-center justify-center rounded-full bg-cyan-400/20 text-cyan-400 text-xs">✓</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="relative rounded-2xl border border-zinc-800 bg-zinc-900/40 p-8 lg:p-12" data-animation="scale">
           <div class="flex flex-col gap-4">
              <div class="flex justify-between items-center text-xs font-mono text-zinc-500">
                 <span>AUDIT_SCAN_V2.0</span>
                 <span class="text-cyan-400">STATUS: KONFORM</span>
              </div>
              <div class="h-2 w-full bg-zinc-800 rounded-full overflow-hidden">
                 <div class="h-full bg-cyan-400" style="width: 92%"></div>
              </div>
              <div class="grid grid-cols-2 gap-4 mt-2">
                 <div class="p-3 rounded-lg bg-zinc-800/50 border border-zinc-700">
                    <p class="text-[10px] text-zinc-500 uppercase">Wahrnehmbar</p>
                    <p class="text-lg font-bold">100%</p>
                 </div>
                 <div class="p-3 rounded-lg bg-zinc-800/50 border border-zinc-700">
                    <p class="text-[10px] text-zinc-500 uppercase">Bedienbar</p>
                    <p class="text-lg font-bold">88%</p>
                 </div>
              </div>
           </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Methodology Section -->
  <section id="framework" class="px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16 text-center" data-animation="fade-up">
        <h2 class="mb-4 text-3xl font-bold md:text-5xl">Die Accessibility-Roadmap</h2>
        <p class="mx-auto max-w-2xl text-zinc-400">
          Wir kombinieren automatisiertes Scanning mit manueller Expertenbewertung – einschließlich Tests durch Menschen 
          mit Behinderungen – für einen realistischen Weg zur Compliance.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
        {[
          {
            step: "01",
            title: "Audit",
            desc: "Vielschichtige Tests der wichtigsten User-Journeys zur Identifikation technischer und UX-Barrieren.",
            icon: "🔍"
          },
          {
            step: "02",
            title: "Priorisierung",
            desc: "Risikobasierte Klassifizierung der Probleme. Was muss jetzt gefixt werden, um rechtliche Risiken zu vermeiden.",
            icon: "⚖️"
          },
          {
            step: "03",
            title: "Remediation",
            desc: "Developer-zentrierte Anleitung zur Behebung von Fehlern, ohne Features zu beeinträchtigen.",
            icon: "🛠️"
          },
          {
            step: "04",
            title: "Governance",
            desc: "Einführung von Monitoring und Team-Training, um künftige Barrieren zu vermeiden.",
            icon: "📜"
          }
        ].map(item => (
          <div class="group relative rounded-2xl border border-zinc-800 bg-zinc-900/30 p-8 transition-colors hover:border-cyan-400/40" data-animation="fade-up">
            <span class="absolute top-4 right-6 text-4xl font-black text-zinc-800/50 transition-colors group-hover:text-cyan-400/10">{item.step}</span>
            <div class="mb-6 text-3xl">{item.icon}</div>
            <h3 class="mb-3 text-xl font-semibold">{item.title}</h3>
            <p class="text-sm text-zinc-400 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Specialized Middle Section -->
  <section class="bg-gradient-to-b from-zinc-950 to-zinc-900 px-6 py-24 overflow-hidden">
    <div class="mx-auto max-w-6xl">
      <div class="rounded-3xl border border-cyan-400/20 bg-cyan-950/5 p-8 md:p-16 lg:flex items-center gap-16" data-animation="fade-up">
        <div class="lg:w-1/2">
          <div class="mb-6 inline-flex rounded-full bg-cyan-400/10 px-4 py-1 text-xs font-semibold text-cyan-300">
            Expert-Led Validation
          </div>
          <h2 class="mb-6 text-3xl font-bold md:text-4xl">Automatisierung findet 30%. Menschen den Rest.</h2>
          <p class="mb-8 text-zinc-400">
            Tools wie Axe und Lighthouse sind ein guter Start, aber sie erfassen nicht die Nuancen einer echten User-Journey. 
            Unsere Audits beinhalten manuelle Tests mit Screenreadern (NVDA, JAWS, VoiceOver) und Tastatur-Navigation, 
            um echte Nutzbarkeit sicherzustellen.
          </p>
          <div class="grid gap-6 sm:grid-cols-2">
            <div>
              <h4 class="mb-2 font-semibold text-zinc-200">Screenreader-UX</h4>
              <p class="text-xs text-zinc-400">Sicherstellung einer semantischen Struktur und korrekter Aria-Labels.</p>
            </div>
            <div>
              <h4 class="mb-2 font-semibold text-zinc-200">Assistive Tech</h4>
              <p class="text-xs text-zinc-400">Tests mit Switch-Controls und Sprache-zu-Text-Software.</p>
            </div>
          </div>
        </div>
        <div class="mt-12 lg:mt-0 lg:w-1/2 relative flex justify-center">
           <div class="w-full max-w-sm rounded-2xl border border-zinc-800 bg-zinc-900 p-6 shadow-2xl">
              <div class="flex items-center gap-4 mb-6">
                 <div class="h-3 w-3 rounded-full bg-red-500"></div>
                 <div class="h-3 w-3 rounded-full bg-yellow-500"></div>
                 <div class="h-3 w-3 rounded-full bg-green-500"></div>
              </div>
              <div class="space-y-4">
                 <div class="h-4 w-3/4 bg-zinc-800 rounded"></div>
                 <div class="h-20 w-full bg-zinc-800 rounded flex items-center justify-center">
                    <span class="text-2xl opacity-20">♿</span>
                 </div>
                 <div class="space-y-2">
                    <div class="h-3 w-full bg-zinc-800 rounded"></div>
                    <div class="h-3 w-5/6 bg-zinc-800 rounded"></div>
                 </div>
                 <div class="pt-4 flex justify-between">
                    <div class="h-8 w-24 bg-cyan-400/20 rounded border border-cyan-400/50"></div>
                    <div class="h-8 w-24 bg-zinc-800 rounded"></div>
                 </div>
              </div>
           </div>
           <div class="absolute -bottom-6 -right-6 p-4 rounded-lg bg-zinc-800 border border-zinc-700 shadow-xl hidden sm:block" data-animation="scale">
              <p class="text-[10px] font-bold text-cyan-300 mb-1">VOICEOVER AUSGABE:</p>
              <p class="text-xs italic text-zinc-400">"Bestellung absenden, Button. Drücken Sie Enter zum Bestätigen."</p>
           </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Focus Areas -->
  <section class="px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16" data-animation="fade-up">
        <h2 class="mb-4 text-3xl font-bold">Spezialisierte Compliance-Leistungen</h2>
        <p class="text-zinc-400">Tiefe Expertise für jede Phase Ihrer Accessibility-Journey.</p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {[
          {
            title: "WCAG 2.1 / 2.2 Audit",
            desc: "Umfassende Bewertung Ihrer Web- oder Mobile-Plattform nach den neuesten internationalen Standards.",
            icon: "📜"
          },
          {
            title: "EAA Readiness-Check",
            desc: "Ein strategisches Audit fokussiert auf die rechtlichen Anforderungen des European Accessibility Act.",
            icon: "🇪🇺"
          },
          {
            title: "VPAT / ACR Erstellung",
            desc: "Professionelle Dokumentation für öffentliche Aufträge und Enterprise-Ausschreibungen.",
            icon: "📝"
          },
          {
            title: "Accessible Design Systems",
            desc: "Barrierefreiheit direkt in die Core-Komponenten einbauen, um Probleme im Keim zu ersticken.",
            icon: "🧱"
          }
        ].map(service => (
          <div class="flex gap-6 rounded-2xl border border-zinc-800 bg-zinc-900/20 p-8 transition-colors hover:bg-zinc-900/40" data-animation="fade-up">
            <div class="text-3xl shrink-0">{service.icon}</div>
            <div>
              <h3 class="mb-2 text-xl font-semibold">{service.title}</h3>
              <p class="text-sm text-zinc-400">{service.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="border-t border-zinc-900 px-6 py-24">
    <div class="mx-auto max-w-3xl">
      <h2 class="mb-12 text-center text-3xl font-bold md:text-4xl" data-animation="fade-up">Accessibility FAQ</h2>
      <div class="space-y-6" data-animation="fade-up">
        {[
          {
            q: "Wann tritt der European Accessibility Act (EAA) in Kraft?",
            a: "Der EAA (Richtlinie 2019/882) muss ab dem 28. Juni 2025 angewendet werden. Unternehmen sollten jetzt mit der Umsetzung beginnen, um rechtzeitig fertig zu sein."
          },
          {
            q: "Warum reicht automatisiertes Testing nicht aus?",
            a: "Automatisierte Tools finden nur ca. 30% der Fehler. Manuelle Tests durch Experten sind nötig, um Logikfehler, Fokus-Management und Screenreader-UX zu bewerten."
          },
          {
            q: "Wie lange dauert ein vollständiges Audit?",
            a: "Ein typisches Audit für eine Web-Applikation oder eine Kern-E-Commerce Journey dauert ca. 2-3 Wochen inkl. Bericht und Workshop."
          },
          {
            q: "Ruiniert Barrierefreiheit das Design?",
            a: "Nein. Barrierefreies Design ist einfach gutes Design. Wir setzen auf 'Inclusive UX', die die Nutzbarkeit für alle verbessert, ohne den Brand-Aesthetic zu schaden."
          }
        ].map(item => (
          <div class="rounded-xl border border-zinc-800 bg-zinc-900/40 p-6">
            <h3 class="mb-3 font-semibold text-zinc-200">{item.q}</h3>
            <p class="text-sm text-zinc-400 leading-relaxed">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="px-6 py-24 text-center">
    <div class="mx-auto max-w-4xl rounded-3xl bg-gradient-to-br from-cyan-400/20 to-violet-400/20 p-12 md:p-24 border border-zinc-800" data-animation="scale">
      <h2 class="mb-6 text-3xl font-bold md:text-5xl tracking-tight">Bereit für ein inklusives Produkt?</h2>
      <p class="mx-auto mb-10 max-w-xl text-lg text-zinc-300">
        Sprechen Sie mit unseren Accessibility-Leads. Wir helfen Ihnen, konform zu werden, ohne Ihr Team auszubremsen.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/de/contact"
          class="rounded-lg bg-cyan-400 px-8 py-4 font-semibold text-zinc-950 transition-colors hover:bg-cyan-300"
        >
          Audit-Gespräch buchen
        </a>
        <a
          href="mailto:hola@ai-native.es"
          class="rounded-lg border border-zinc-700 bg-zinc-950 px-8 py-4 text-zinc-300 transition-colors hover:border-cyan-400/50"
        >
          E-Mail senden
        </a>
      </div>
    </div>
  </section>
</Layout>
