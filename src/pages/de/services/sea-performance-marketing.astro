---
import Layout from '../../../layouts/Layout.astro';
import { ChevronRight } from '../../../components/FeatherIcons.ts';
---

<Layout
  lang="de"
  title="SEA & Performance Marketing Audits | Hound | ai-native"
  description="Experten-geführte SEA Deep-Dives, die über operative Verwaltung hinausgehen, um strukturelle Wachstumshebel in Ihren Google Ads und Microsoft Advertising Konten aufzudecken."
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden px-6 pb-32 pt-24 md:pt-32">
    <div class="absolute inset-0 -z-10 opacity-20">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-cyan-500/20 rounded-full blur-3xl animate-pulse" />
      <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-violet-500/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s" />
    </div>

    <div class="mx-auto max-w-5xl text-center" data-animation="fade-up">
      <p class="mb-4 text-xs font-semibold uppercase tracking-[0.3em] text-cyan-300">
        Strategic Paid Growth
      </p>
      <h1 class="mb-6 text-4xl font-bold tracking-tight md:text-6xl lg:text-7xl">
        Hören Sie auf zu verwalten. <span class="bg-gradient-to-r from-cyan-300 to-violet-400 bg-clip-text text-transparent">Fangen Sie an zu skalieren.</span>
      </h1>
      <p class="mx-auto mb-10 max-w-3xl text-lg text-zinc-400 md:text-xl">
        Die meisten SEA-Konten stecken in der operativen Routine fest. Wir betrachten Ihr Paid Search als System und 
        identifizieren die strukturellen Hebel, die ROI und EBITDA wirklich bewegen.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/de/contact"
          class="rounded-lg bg-cyan-400 px-8 py-4 font-semibold text-zinc-950 transition-colors hover:bg-cyan-300"
        >
          SEA-Audit anfragen
        </a>
        <a
          href="#methodik"
          class="rounded-lg border border-zinc-700 px-8 py-4 text-zinc-300 transition-colors hover:border-cyan-400/50 hover:text-cyan-300"
        >
          Unser Ansatz
        </a>
      </div>
    </div>
  </section>

  <!-- Value Proposition -->
  <section class="border-y border-zinc-900 bg-zinc-950/50 px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-12 lg:grid-cols-2 items-center">
        <div data-animation="fade-up">
          <h2 class="mb-6 text-3xl font-bold md:text-4xl">SEA ist ein System, keine Checkliste</h2>
          <p class="mb-6 text-zinc-400">
            Inspiriert von Spezialisten wie The Boutique Agency gehen wir über einfache Fehleranalyse hinaus. 
            Wir analysieren das Zusammenspiel von Automation, Gebotsstrategien und Kontostrukturen mit Ihren 
            Business-Zielen. Unser Ziel: Wo stagniert die Performance und warum?
          </p>
          <ul class="space-y-4">
            {[
              "Systemische Analyse der Kontarchitektur",
              "Kritische Prüfung von 'Black Box' Automation & Smart Bidding",
              "Deep-Dive in GA4- & Tracking-Datenqualität",
              "Actionable Roadmap für strukturelles Wachstum"
            ].map(item => (
              <li class="flex items-center gap-3 text-zinc-300">
                <span class="flex h-5 w-5 items-center justify-center rounded-full bg-cyan-400/20 text-cyan-400 text-xs">✓</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="relative rounded-2xl border border-zinc-800 bg-zinc-900/40 p-8 lg:p-12" data-animation="scale">
           <div class="space-y-6">
              <div class="flex justify-between items-end border-b border-zinc-800 pb-4">
                 <div>
                    <p class="text-xs text-zinc-500 uppercase tracking-widest">Wachstumshebel identifiziert</p>
                    <p class="text-2xl font-bold text-cyan-300">Efficiency Audit</p>
                 </div>
                 <div class="text-right">
                    <p class="text-xs text-zinc-500">Wasted Spend</p>
                    <p class="text-sm font-semibold text-red-400">-18%</p>
                 </div>
              </div>
              <div class="grid grid-cols-5 gap-1 h-20 items-end">
                 {[40, 60, 45, 90, 100].map(h => (
                    <div class="bg-gradient-to-t from-cyan-400/40 to-cyan-400 rounded-sm w-full" style={`height: ${h}%`}></div>
                 ))}
              </div>
              <p class="text-[10px] text-zinc-500 text-center font-mono">STRUCTURAL_OPTIMIZATION_V4</p>
           </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Methodology Section -->
  <section id="methodik" class="px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16 text-center" data-animation="fade-up">
        <h2 class="mb-4 text-3xl font-bold md:text-5xl">Das Efficiency Audit</h2>
        <p class="mx-auto max-w-2xl text-zinc-400">
          Wir folgen einem strengen Prozess mit über 90 Audit-Kriterien, um den Status Ihres Kontos 
          zu klassifizieren und eine klare Basis für strategische Entscheidungen zu schaffen.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
        {[
          {
            step: "01",
            title: "Analyse",
            desc: "Systemische Bewertung von Keyword-Logik, Targeting und Kontohierarchie.",
            icon: "📊"
          },
          {
            step: "02",
            title: "Validation",
            desc: "Technischer Deep-Dive in Tracking, Attribution und GA4-Datenintegrität.",
            icon: "🧪"
          },
          {
            step: "03",
            title: "Automation",
            desc: "Kritische Prüfung von Gebotsstrategien und KI-gestützter Kampagnenperformance.",
            icon: "🤖"
          },
          {
            step: "04",
            title: "Roadmap",
            desc: "Ein priorisierter Plan zur Budget-Umschichtung von Kostentreffern zu Wachstumshebeln.",
            icon: "📈"
          }
        ].map(item => (
          <div class="group relative rounded-2xl border border-zinc-800 bg-zinc-900/30 p-8 transition-colors hover:border-cyan-400/40" data-animation="fade-up">
            <span class="absolute top-4 right-6 text-4xl font-black text-zinc-800/50 transition-colors group-hover:text-cyan-400/10">{item.step}</span>
            <div class="mb-6 text-3xl">{item.icon}</div>
            <h3 class="mb-3 text-xl font-semibold">{item.title}</h3>
            <p class="text-sm text-zinc-400 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Specialized Middle Section -->
  <section class="bg-gradient-to-b from-zinc-950 to-zinc-900 px-6 py-24 overflow-hidden">
    <div class="mx-auto max-w-6xl">
      <div class="rounded-3xl border border-cyan-400/20 bg-cyan-950/5 p-8 md:p-16 lg:flex items-center gap-16" data-animation="fade-up">
        <div class="lg:w-1/2">
          <div class="mb-6 inline-flex rounded-full bg-cyan-400/10 px-4 py-1 text-xs font-semibold text-cyan-300">
            Automation Quality Control
          </div>
          <h2 class="mb-6 text-3xl font-bold md:text-4xl">Vertrauen Sie der Black Box nicht blind.</h2>
          <p class="mb-8 text-zinc-400">
            Modernes SEA wird stark von Googles Algorithmen (PMax, Smart Bidding) gesteuert. 
            Aber Algorithmen sind nur so gut wie die Daten, die sie erhalten. Wir prüfen Ihr 
            Setup, um sicherzustellen, dass es echtem Business-Value nachjagt, nicht nur 
            plattformspezifischen Vanity-Metrics.
          </p>
          <div class="grid gap-6 sm:grid-cols-2">
            <div>
              <h4 class="mb-2 font-semibold text-zinc-200">Data Quality Audit</h4>
              <p class="text-xs text-zinc-400">Sicherstellung sauberer und korrekt gewichteter Conversion-Signale.</p>
            </div>
            <div>
              <h4 class="mb-2 font-semibold text-zinc-200">Strategic Steering</h4>
              <p class="text-xs text-zinc-400">Ausrichtung automatisierter Gebote an Ihren realen Margen- und LTV-Zielen.</p>
            </div>
          </div>
        </div>
        <div class="mt-12 lg:mt-0 lg:w-1/2 relative">
           <div class="p-8 rounded-2xl border border-zinc-800 bg-zinc-900/40 backdrop-blur-sm">
              <div class="flex items-center gap-4 mb-8">
                 <div class="h-10 w-10 rounded bg-cyan-400/20 flex items-center justify-center text-cyan-400">AI</div>
                 <div>
                    <p class="text-sm font-bold">Bidding Algorithm</p>
                    <p class="text-[10px] text-zinc-500">CURRENT_MODE: OPTIMIZING</p>
                 </div>
              </div>
              <div class="space-y-4">
                 <div class="flex justify-between text-[10px] font-mono">
                    <span class="text-zinc-500">SIGNAL_STRENGTH</span>
                    <span class="text-cyan-400">HIGH</span>
                 </div>
                 <div class="h-1 w-full bg-zinc-800 rounded-full">
                    <div class="h-full bg-cyan-400" style="width: 85%"></div>
                 </div>
                 <div class="p-4 rounded-lg bg-zinc-950 border border-zinc-800 mt-4">
                    <p class="text-[10px] text-zinc-500 mb-2 uppercase">Empfehlung</p>
                    <p class="text-xs text-zinc-300 italic">"Verschieben Sie 15% Budget von Broad-Match Generic zu High-Intent lokalisierten Kampagnen."</p>
                 </div>
              </div>
           </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Focus Areas -->
  <section class="px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16" data-animation="fade-up">
        <h2 class="mb-4 text-3xl font-bold">Spezialisierte SEA-Leistungen</h2>
        <p class="text-zinc-400">Experten-geführte Deep-Dives für reife Werbekonten.</p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {[
          {
            title: "Google Ads Strategic Audit",
            desc: "Umfassender 90-Punkte-Check über Kontostruktur, Gebote und Datenqualität.",
            icon: "🔍"
          },
          {
            title: "Tracking & GA4 Integration",
            desc: "Sicherstellung, dass Ihre Messungen eine solide Basis für automatisierte Entscheidungen bieten.",
            icon: "📊"
          },
          {
            title: "PMax & Automation Audit",
            desc: "Öffnen der 'Black Box', um zu verstehen, was Ihre Performance Max Kampagnen wirklich antreibt.",
            icon: "🤖"
          },
          {
            title: "Internationales SEA-Scaling",
            desc: "Strategische Begleitung für Marken bei der Expansion in DACH- und europäische Märkte.",
            icon: "🌍"
          }
        ].map(service => (
          <div class="flex gap-6 rounded-2xl border border-zinc-800 bg-zinc-900/20 p-8 transition-colors hover:bg-zinc-900/40" data-animation="fade-up">
            <div class="text-3xl shrink-0">{service.icon}</div>
            <div>
              <h3 class="mb-2 text-xl font-semibold">{service.title}</h3>
              <p class="text-sm text-zinc-400">{service.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="border-t border-zinc-900 px-6 py-24">
    <div class="mx-auto max-w-3xl">
      <h2 class="mb-12 text-center text-3xl font-bold md:text-4xl" data-animation="fade-up">SEA Audit FAQ</h2>
      <div class="space-y-6" data-animation="fade-up">
        {[
          {
            q: "Für wen ist dieses Audit geeignet?",
            a: "Meist für Unternehmen mit €20k+ Spend pro Monat, die das Gefühl haben zu stagnieren oder die Kontrolle über die Automation zu verlieren."
          },
          {
            q: "Betreuen Sie Konten auch dauerhaft?",
            a: "Unser Fokus liegt auf High-Impact Audits und strukturellem Neuaufbau. Für das laufende Management coachen wir Inhouse-Teams oder arbeiten mit Partner-Boutiquen."
          },
          {
            q: "Wie lange dauert ein SEA-Audit?",
            a: "Ein Deep-Dive Audit dauert typischerweise 10-14 Tage inkl. Analyse und Präsentation der Roadmap."
          },
          {
            q: "Was benötigen Sie für den Start?",
            a: "Read-Only Zugriff auf Google Ads und GA4, sowie ein kurzes Briefing zu Ihren Business-KPIs (Marge, LTV etc.)."
          }
        ].map(item => (
          <div class="rounded-xl border border-zinc-800 bg-zinc-900/40 p-6">
            <h3 class="mb-3 font-semibold text-zinc-200">{item.q}</h3>
            <p class="text-sm text-zinc-400 leading-relaxed">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="px-6 py-24 text-center">
    <div class="mx-auto max-w-4xl rounded-3xl bg-gradient-to-br from-cyan-400/20 to-violet-400/20 p-12 md:p-24 border border-zinc-800" data-animation="scale">
      <h2 class="mb-6 text-3xl font-bold md:text-5xl tracking-tight">Bereit für einen Performance-Boost?</h2>
      <p class="mx-auto mb-10 max-w-xl text-lg text-zinc-300">
        Erhalten Sie eine Experten-Klassifizierung Ihres Kontostatus. Keine Account-Manager, nur Senior-Spezialisten.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/de/contact"
          class="rounded-lg bg-cyan-400 px-8 py-4 font-semibold text-zinc-950 transition-colors hover:bg-cyan-300"
        >
          SEA-Audit besprechen
        </a>
        <a
          href="mailto:hola@ai-native.es"
          class="rounded-lg border border-zinc-700 bg-zinc-950 px-8 py-4 text-zinc-300 transition-colors hover:border-cyan-400/50"
        >
          E-Mail senden
        </a>
      </div>
    </div>
  </section>
</Layout>
