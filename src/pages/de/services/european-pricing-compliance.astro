---
import Layout from '../../../layouts/Layout.astro';
import { ChevronRight } from '../../../components/FeatherIcons.ts';
---

<Layout
  lang="de"
  title="Europäische Preis-Compliance & Omnibus-UX | Hound | ai-native"
  description="Richten Sie Ihre E-Commerce-Preise und Promotionen an der EU-Preisangabenrichtlinie (PID) und den Omnibus-Regeln aus, ohne Ihre Conversion-Raten zu gefährden."
>
  <!-- Hero Section -->
  <section class="service-hero-section relative overflow-hidden px-6 pb-32 pt-24 md:pt-32">
    <div class="absolute inset-0 -z-10 opacity-20">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-cyan-500/20 rounded-full blur-3xl animate-pulse" />
      <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-violet-500/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s" />
    </div>

    <div class="mx-auto max-w-5xl text-center" data-animation="fade-up">
      <p class="mb-4 text-xs font-semibold uppercase tracking-[0.3em] text-cyan-300">
        Legal-Ready UX
      </p>
      <h1 class="mb-6 text-4xl font-bold tracking-tight md:text-6xl lg:text-7xl">
        Compliance, die Ihre Conversion <span class="bg-gradient-to-r from-cyan-300 to-violet-400 bg-clip-text text-transparent">nicht killt.</span>
      </h1>
      <p class="mx-auto mb-10 max-w-3xl text-lg text-zinc-400 md:text-xl">
        Die EU-Preisangabenrichtlinie und die Omnibus-Regeln haben die Spielregeln für Rabatte verändert. 
        Wir helfen E-Commerce-Teams, die '30-Tage-Regel' und Preistransparenz durch performante UX-Patterns umzusetzen.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/de/contact"
          class="rounded-lg bg-cyan-400 px-8 py-4 font-semibold text-zinc-950 transition-colors hover:bg-cyan-300"
        >
          Pricing-UX-Audit buchen
        </a>
        <a
          href="#anforderungen"
          class="rounded-lg border border-zinc-700 px-8 py-4 text-zinc-300 transition-colors hover:border-cyan-400/50 hover:text-cyan-300"
        >
          Anforderungen ansehen
        </a>
      </div>
    </div>
  </section>

  <!-- Value Proposition -->
  <section class="border-y border-zinc-900 bg-zinc-950/50 px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-12 lg:grid-cols-2 items-center">
        <div data-animation="fade-up">
          <h2 class="mb-6 text-3xl font-bold md:text-4xl">Preistransparenz ist das neue Vertrauenssignal</h2>
          <p class="mb-6 text-zinc-400">
            Die Verbraucherschutzgesetze in der EU werden strenger. Irreführende Rabatte oder fehlende Grundpreise 
            sind kein "schlechtes UX" mehr – sie sind ein hohes rechtliches Risiko. Wir schließen die Lücke zwischen 
            Legal-Anforderungen und Wachstums-KPIs.
          </p>
          <ul class="space-y-4">
            {[
              "Automatisierte Anzeige des 'Niedrigsten Preises der letzten 30 Tage'",
              "Rechtskonforme Grundpreisangaben (pro kg/L)",
              "Transparente Rabatt- & Aktions-UX-Patterns",
              "Schutz vor Abmahnungen wegen unlauterem Wettbewerb"
            ].map(item => (
              <li class="flex items-center gap-3 text-zinc-300">
                <span class="flex h-5 w-5 items-center justify-center rounded-full bg-cyan-400/20 text-cyan-400 text-xs">✓</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="relative rounded-2xl border border-zinc-800 bg-zinc-900/40 p-8 lg:p-12" data-animation="scale">
           <div class="space-y-4">
              <div class="flex justify-between items-center text-xs text-zinc-500 uppercase tracking-widest">
                 <span>PDP // COMPLIANCE_VIEW</span>
                 <span class="text-green-400">PASSED</span>
              </div>
              <div class="p-6 rounded-xl bg-zinc-950 border border-zinc-800">
                 <p class="text-sm text-zinc-400 line-through">99,99 €</p>
                 <div class="flex items-baseline gap-3">
                    <p class="text-3xl font-bold text-zinc-100">79,99 €</p>
                    <span class="px-2 py-0.5 rounded bg-red-500/10 text-red-500 text-[10px] font-bold">-20%</span>
                 </div>
                 <p class="mt-2 text-[10px] text-zinc-500 italic">
                    Niedrigster Preis der letzten 30 Tage: 79,99 €
                 </p>
                 <div class="mt-4 pt-4 border-t border-zinc-900 text-[10px] text-zinc-500">
                    Preis pro kg: 15,99 €
                 </div>
              </div>
           </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Methodology Section -->
  <section id="anforderungen" class="px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16 text-center" data-animation="fade-up">
        <h2 class="mb-4 text-3xl font-bold md:text-5xl">Der Compliance-Workflow</h2>
        <p class="mx-auto max-w-2xl text-zinc-400">
          Wir übersetzen komplexe EU-Richtlinien in konkrete UI-Komponenten und Datenanforderungen 
          für Ihre Engineering- und Trading-Teams.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
        {[
          {
            step: "01",
            title: "Audit",
            desc: "Abgleich Ihrer aktuellen Preisdarstellung mit den Anforderungen der PAngV und Omnibus-Richtlinie.",
            icon: "⚖️"
          },
          {
            step: "02",
            title: "Redesign",
            desc: "Entwurf von UI-Varianten, die rechtlich sicher sind und dennoch 'Urgency' und CR bewahren.",
            icon: "📐"
          },
          {
            step: "03",
            title: "Implement",
            desc: "Technische Beratung zum 30-Tage-Preis-Logging und zur dynamischen Grundpreisberechnung.",
            icon: "💻"
          },
          {
            step: "04",
            title: "Dokument",
            desc: "Klare interne Richtlinien für Trading-Teams, damit künftige Promos rechtssicher bleiben.",
            icon: "📂"
          }
        ].map(item => (
          <div class="group relative rounded-2xl border border-zinc-800 bg-zinc-900/30 p-8 transition-colors hover:border-cyan-400/40" data-animation="fade-up">
            <span class="absolute top-4 right-6 text-4xl font-black text-zinc-800/50 transition-colors group-hover:text-cyan-400/10">{item.step}</span>
            <div class="mb-6 text-3xl">{item.icon}</div>
            <h3 class="mb-3 text-xl font-semibold">{item.title}</h3>
            <p class="text-sm text-zinc-400 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Specialized Middle Section -->
  <section class="bg-gradient-to-b from-zinc-950 to-zinc-900 px-6 py-24 overflow-hidden">
    <div class="mx-auto max-w-6xl">
      <div class="rounded-3xl border border-violet-400/20 bg-violet-950/5 p-8 md:p-16 lg:flex items-center gap-16" data-animation="fade-up">
        <div class="lg:w-1/2">
          <div class="mb-6 inline-flex rounded-full bg-violet-400/10 px-4 py-1 text-xs font-semibold text-violet-300">
            Strategische Preis-UX
          </div>
          <h2 class="mb-6 text-3xl font-bold md:text-4xl">Lösen Sie das 'Omnibus'-Designproblem.</h2>
          <p class="mb-8 text-zinc-400">
            Die meisten juristischen Gutachten sind unmöglich umzusetzen, ohne Ihre Produktseiten zu ruinieren. 
            Wir haben Jahre bei großen europäischen Retailern verbracht, um genau das zu lösen: Wie man 
            Pflichtangaben so darstellt, dass sie Teil der Marke wirken und nicht wie ein Warnhinweis.
          </p>
          <div class="space-y-4">
            <div class="flex items-start gap-4">
              <div class="h-1 w-12 mt-3 bg-violet-400 shrink-0"></div>
              <p class="text-sm text-zinc-300"><strong class="text-zinc-100">Smart Hierarchy:</strong> Pflichtinfos dort platzieren, wo sie das Gesetz erfüllen, ohne vom CTA abzulenken.</p>
            </div>
            <div class="flex items-start gap-4">
              <div class="h-1 w-12 mt-3 bg-violet-400 shrink-0"></div>
              <p class="text-sm text-zinc-300"><strong class="text-zinc-100">Mobile Optimization:</strong> Sicherstellung, dass Multi-Preis-Anzeigen auf kleinen Screens lesbar bleiben.</p>
            </div>
          </div>
        </div>
        <div class="mt-12 lg:mt-0 lg:w-1/2 relative flex justify-center">
           <div class="w-full max-w-xs aspect-[9/16] rounded-3xl border-[6px] border-zinc-800 bg-zinc-950 overflow-hidden shadow-2xl p-4">
              <div class="h-1 w-12 bg-zinc-800 rounded-full mx-auto mb-6"></div>
              <div class="h-40 w-full bg-zinc-900 rounded-xl mb-6"></div>
              <div class="space-y-4">
                 <div class="h-6 w-3/4 bg-zinc-900 rounded"></div>
                 <div class="space-y-2">
                    <div class="h-3 w-1/4 bg-zinc-800 rounded"></div>
                    <div class="flex gap-2">
                       <div class="h-8 w-1/2 bg-zinc-800 rounded"></div>
                       <div class="h-8 w-12 bg-violet-500/20 rounded"></div>
                    </div>
                    <div class="h-2 w-2/3 bg-zinc-900 rounded"></div>
                 </div>
                 <div class="h-12 w-full bg-cyan-400 rounded-xl mt-12"></div>
              </div>
           </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Focus Areas -->
  <section class="px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16" data-animation="fade-up">
        <h2 class="mb-4 text-3xl font-bold">Spezialisierte Pricing-Leistungen</h2>
        <p class="text-zinc-400">Tiefe Expertise im europäischen Verbraucherschutzrecht und digitalen Handel.</p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {[
          {
            title: "30-Tage-Regel Umsetzung",
            desc: "Redesign Ihrer Rabattlogik zur Anzeige des niedrigsten Preises der letzten 30 Tage gemäß PID / PAngV.",
            icon: "📅"
          },
          {
            title: "Grundpreis-Optimierung",
            desc: "Sicherstellung korrekter und sichtbarer Grundpreise in allen PLPs und Suchergebnissen.",
            icon: "⚖️"
          },
          {
            title: "Promotion & Coupon UX",
            desc: "Neugestaltung des Zusammenspiels von Gutscheinen und Streichpreisen für maximale Transparenz.",
            icon: "🎟️"
          },
          {
            title: "Omnibus Legal-UX Audit",
            desc: "Vollständiger Check Ihrer Plattform auf 'Dark Patterns', die gegen neue Richtlinien verstoßen könnten.",
            icon: "🔍"
          }
        ].map(service => (
          <div class="flex gap-6 rounded-2xl border border-zinc-800 bg-zinc-900/20 p-8 transition-colors hover:bg-zinc-900/40" data-animation="fade-up">
            <div class="text-3xl shrink-0">{service.icon}</div>
            <div>
              <h3 class="mb-2 text-xl font-semibold">{service.title}</h3>
              <p class="text-sm text-zinc-400">{service.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="border-t border-zinc-900 px-6 py-24">
    <div class="mx-auto max-w-3xl">
      <h2 class="mb-12 text-center text-3xl font-bold md:text-4xl" data-animation="fade-up">Pricing Compliance FAQ</h2>
      <div class="space-y-6" data-animation="fade-up">
        {[
          {
            q: "Was besagt die '30-Tage-Regel'?",
            a: "Bei Preisermäßigungen muss der niedrigste Gesamtpreis angegeben werden, den der Händler innerhalb der letzten 30 Tage vor der Ermäßigung angewendet hat. Künstliches Hochsetzen kurz vor dem Sale ist untersagt."
          },
          {
            q: "Gilt das für alle Produkte?",
            a: "Grundsätzlich ja. Ausnahmen gibt es für schnell verderbliche Waren oder Produkte, die erst seit kurzem im Sortiment sind. Für die meisten E-Commerce-Kategorien ist es Pflicht."
          },
          {
            q: "Schadet die Anzeige des 30-Tage-Preises dem Umsatz?",
            a: "Nur wenn sie schlecht gestaltet ist. Wir setzen auf UX-Patterns, die Transparenz als Vertrauenssignal nutzen, was langfristig die Kundenbindung stärkt."
          },
          {
            q: "Reicht ein Tooltip für die 30-Tage-Info aus?",
            a: "Das Gesetz fordert eine 'klare und unmissverständliche' Angabe. Ein versteckter Tooltip könnte bei einer Prüfung problematisch sein. Wir entwerfen Patterns, die auffällig und dennoch ästhetisch sind."
          }
        ].map(item => (
          <div class="rounded-xl border border-zinc-800 bg-zinc-900/40 p-6">
            <h3 class="mb-3 font-semibold text-zinc-200">{item.q}</h3>
            <p class="text-sm text-zinc-400 leading-relaxed">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="px-6 py-24 text-center">
    <div class="mx-auto max-w-4xl rounded-3xl bg-gradient-to-br from-cyan-400/20 to-violet-400/20 p-12 md:p-24 border border-zinc-800" data-animation="scale">
      <h2 class="mb-6 text-3xl font-bold md:text-5xl tracking-tight">Bereit für ein Pricing-UX-Audit?</h2>
      <p class="mx-auto mb-10 max-w-xl text-lg text-zinc-300">
        Sprechen Sie mit unseren Senior-Partnern über Ihr Setup. Wir helfen Ihnen, die Brücke zwischen Legal und Growth zu schlagen.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/de/contact"
          class="rounded-lg bg-cyan-400 px-8 py-4 font-semibold text-zinc-950 transition-colors hover:bg-cyan-300"
        >
          Compliance-Themen besprechen
        </a>
        <a
          href="mailto:hola@ai-native.es"
          class="rounded-lg border border-zinc-700 bg-zinc-950 px-8 py-4 text-zinc-300 transition-colors hover:border-cyan-400/50"
        >
          E-Mail senden
        </a>
      </div>
    </div>
  </section>
</Layout>
