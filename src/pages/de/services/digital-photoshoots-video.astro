---
import Layout from '../../../layouts/Layout.astro';
import { ChevronRight } from '../../../components/FeatherIcons.ts';
---

<Layout
  lang="de"
  title="Digitale Fotoshootings & Videoproduktion | Hound | ai-native"
  description="Strategisches visuelles Storytelling und High-End-Produktion für Marken, die Komplexität vereinfachen wollen. Von Kampagnenfilmen bis hin zu KI-beschleunigten Content-Systemen."
>
  <!-- Hero Section -->
  <section class="service-hero-section relative overflow-hidden px-6 pb-32 pt-24 md:pt-32">
    <div class="absolute inset-0 -z-20 mask-gradient-to-right">
      <img src="/1_conversion_optimization_.webp" alt="" class="h-full w-full object-cover" />
    </div>
    <div class="absolute inset-0 -z-10 opacity-20">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-cyan-500/20 rounded-full blur-3xl animate-pulse" />
      <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-violet-500/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s" />
    </div>

    <div class="mx-auto max-w-5xl text-center" data-animation="fade-up">
      <p class="mb-4 text-xs font-semibold uppercase tracking-[0.3em] text-cyan-300">
        High-End Visual Production
      </p>
      <h1 class="mb-6 text-4xl font-bold tracking-tight md:text-6xl lg:text-7xl">
        Hören Sie auf, generischen Content zu liefern. <span class="bg-gradient-to-r from-cyan-300 to-violet-400 bg-clip-text text-transparent">Erzählen Sie Geschichten.</span>
      </h1>
      <p class="mx-auto mb-10 max-w-3xl text-lg text-zinc-400 md:text-xl">
        Vielen visuellen Inhalten fehlt die Richtung. Wir agieren als Ihr erweitertes Marketing-Team und übersetzen technische 
        Komplexität in klare, fesselnde visuelle Systeme, die auf jedem Kanal funktionieren.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/de/contact"
          class="rounded-lg bg-cyan-400 px-8 py-4 font-semibold text-zinc-950 transition-colors hover:bg-cyan-300"
        >
          Produktions-Call buchen
        </a>
        <a
          href="#prozess"
          class="rounded-lg border border-zinc-700 px-8 py-4 text-zinc-300 transition-colors hover:border-cyan-400/50 hover:text-cyan-300"
        >
          Unser Prozess
        </a>
      </div>
    </div>
  </section>

  <!-- Value Proposition -->
  <section class="border-y border-zinc-900 bg-zinc-950/50 px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-12 lg:grid-cols-2 items-center">
        <div data-animation="fade-up">
          <h2 class="mb-6 text-3xl font-bold md:text-4xl">Visuelles Storytelling für eine komplexe Welt</h2>
          <p class="mb-6 text-zinc-400">
            Inspiriert von Studios wie Visionary Berlin "machen wir nicht nur Fotos". Wir bauen visuelle Identitäten, 
            die den Wert Ihres Produkts sofort begreifbar machen. Ob technische B2B-Lösung oder Premium-Consumer-Brand – 
            wir finden den visuellen Hook, der verbindet.
          </p>
          <ul class="space-y-4">
            {[
              "Strategische Ausrichtung auf Ihre Markenpositionierung",
              "Multi-Channel Asset-Systeme (Web, Social, Print)",
              "Schnelle Produktionszyklen",
              "Hybrides Modell: Handwerk + KI-Beschleunigung"
            ].map(item => (
              <li class="flex items-center gap-3 text-zinc-300">
                <span class="flex h-5 w-5 items-center justify-center rounded-full bg-cyan-400/20 text-cyan-400 text-xs">✓</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="relative rounded-2xl border border-zinc-800 bg-zinc-900/40 p-8 lg:p-12" data-animation="scale">
          <div class="absolute -top-4 -right-4 h-24 w-24 rounded-full bg-violet-500/10 blur-2xl" />
          <div class="space-y-6 text-center">
             <div class="flex justify-center gap-2">
                <div class="h-2 w-8 rounded-full bg-cyan-400"></div>
                <div class="h-2 w-8 rounded-full bg-zinc-800"></div>
                <div class="h-2 w-8 rounded-full bg-zinc-800"></div>
             </div>
             <p class="text-xl font-medium text-zinc-200">"Sie haben nicht nur ein Video geliefert, sondern eine visuelle Strategie, die unsere Social-Präsenz neu definiert hat."</p>
             <div class="pt-4 border-t border-zinc-800">
                <p class="text-xs font-bold uppercase tracking-widest text-cyan-300">Creative Lead</p>
                <p class="text-[10px] text-zinc-500">Europäisches Scale-up</p>
             </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Methodology Section -->
  <section id="prozess" class="px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16 text-center" data-animation="fade-up">
        <h2 class="mb-4 text-3xl font-bold md:text-5xl">Der Produktions-Loop</h2>
        <p class="mx-auto max-w-2xl text-zinc-400">
          Wir kombinieren klassische kreative Direktion mit modernen technischen Tools, um High-Impact-Visuals 
          in der Geschwindigkeit des digitalen Handels zu liefern.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
        {[
          {
            step: "01",
            title: "Strategie",
            desc: "Wir tauchen tief in Ihre Produktlogik ein, um die visuellen Kernbotschaften zu identifizieren.",
            icon: "🧠"
          },
          {
            step: "02",
            title: "Konzept",
            desc: "Storyboards, Moodboards und Shot-Listen, die für kanalübergreifende Konsistenz sorgen.",
            icon: "🎨"
          },
          {
            step: "03",
            title: "Produktion",
            desc: "On-Set oder Digital-First Produktion mit High-End Cinema- und Foto-Equipment.",
            icon: "🎬"
          },
          {
            step: "04",
            title: "Iteration",
            desc: "KI-gestützte Varianten-Generierung und Skalierung für jedes benötigte Format.",
            icon: "🔄"
          }
        ].map(item => (
          <div class="group relative rounded-2xl border border-zinc-800 bg-zinc-900/30 p-8 transition-colors hover:border-cyan-400/40" data-animation="fade-up">
            <span class="absolute top-4 right-6 text-4xl font-black text-zinc-800/50 transition-colors group-hover:text-cyan-400/10">{item.step}</span>
            <div class="mb-6 text-3xl">{item.icon}</div>
            <h3 class="mb-3 text-xl font-semibold">{item.title}</h3>
            <p class="text-sm text-zinc-400 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Creative Middle Section -->
  <section class="bg-gradient-to-b from-zinc-950 to-zinc-900 px-6 py-24 overflow-hidden">
    <div class="mx-auto max-w-6xl">
      <div class="rounded-3xl border border-violet-400/20 bg-violet-950/5 p-8 md:p-16 lg:flex items-center gap-16" data-animation="fade-up">
        <div class="lg:w-1/2">
          <div class="mb-6 inline-flex rounded-full bg-violet-400/10 px-4 py-1 text-xs font-semibold text-violet-300">
            The Content Engine
          </div>
          <h2 class="mb-6 text-3xl font-bold md:text-4xl">Human Craft. AI Speed.</h2>
          <p class="mb-8 text-zinc-400">
            Visuelle Produktion darf kein Flaschenhals sein. Wir nutzen KI für Fleißaufgaben – Hintergrundaustausch, 
            Asset-Lokalisierung und Lichtanpassungen –, damit sich unser Kreativteam auf das Wesentliche konzentrieren kann: 
            die Story und den Impact.
          </p>
          <div class="space-y-4">
            <div class="flex items-start gap-4">
              <div class="h-1 w-12 mt-3 bg-violet-400 shrink-0"></div>
              <p class="text-sm text-zinc-300"><strong class="text-zinc-100">AI Concepting:</strong> Schnelle Pre-Viz, um die Richtung abzustimmen, bevor die Kamera läuft.</p>
            </div>
            <div class="flex items-start gap-4">
              <div class="h-1 w-12 mt-3 bg-violet-400 shrink-0"></div>
              <p class="text-sm text-zinc-300"><strong class="text-zinc-100">Smart Scaling:</strong> Verwandeln Sie einen Hero-Film in über 50 Social-Varianten in Tagen, nicht Wochen.</p>
            </div>
          </div>
        </div>
        <div class="mt-12 lg:mt-0 lg:w-1/2 grid grid-cols-2 gap-4">
           <div class="aspect-[4/5] rounded-xl bg-zinc-900 border border-zinc-800 overflow-hidden relative group">
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent flex items-end p-4">
                 <p class="text-[10px] font-mono text-cyan-300">GEN_01 // PRODUCT_MESH</p>
              </div>
           </div>
           <div class="aspect-[4/5] rounded-xl bg-zinc-800 border border-zinc-700 overflow-hidden relative mt-8">
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent flex items-end p-4">
                 <p class="text-[10px] font-mono text-violet-300">POST_PRO // LIGHT_VAR</p>
              </div>
           </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Focus Areas -->
  <section class="px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16" data-animation="fade-up">
        <h2 class="mb-4 text-3xl font-bold">Produktions-Leistungen</h2>
        <p class="text-zinc-400">Alles, was Sie für ein modernes visuelles Markensystem benötigen.</p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {[
          {
            title: "Brand & Image-Filme",
            desc: "Hochwertige cineastische Filme, die den Kern und die Mission Ihrer Marke einfangen.",
            icon: "🎥"
          },
          {
            title: "Produktfotografie",
            desc: "Technische und Lifestyle-Bilder, die Produkte im Web und Print glänzen lassen.",
            icon: "📸"
          },
          {
            title: "Social-First Content",
            desc: "Kurze vertikale Videos und Motion-Loops, optimiert für maximale Interaktion.",
            icon: "📱"
          },
          {
            title: "Professionelle Livestreams",
            desc: "Livestream-Produktion auf Agenturniveau für Events, Produkt-Launches und Panels.",
            icon: "📡"
          }
        ].map(service => (
          <div class="flex gap-6 rounded-2xl border border-zinc-800 bg-zinc-900/20 p-8 transition-colors hover:bg-zinc-900/40" data-animation="fade-up">
            <div class="text-3xl shrink-0">{service.icon}</div>
            <div>
              <h3 class="mb-2 text-xl font-semibold">{service.title}</h3>
              <p class="text-sm text-zinc-400">{service.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="border-t border-zinc-900 px-6 py-24">
    <div class="mx-auto max-w-3xl">
      <h2 class="mb-12 text-center text-3xl font-bold md:text-4xl" data-animation="fade-up">Produktions-FAQ</h2>
      <div class="space-y-6" data-animation="fade-up">
        {[
          {
            q: "Übernehmen Sie die gesamte Produktion oder nur die Direktion?",
            a: "Beides. Wir agieren entweder als Ihr Creative Lead und steuern externe Crews, oder übernehmen die Full-Cycle-Produktion über unser Inhouse-Team und Partner-Netzwerk."
          },
          {
            q: "Wie setzen Sie KI in Ihrem Video-Prozess ein?",
            a: "Wir nutzen sie für die Visualisierung vorab (Pre-Viz), um Looks zu zeigen, bevor wir drehen, sowie für Hintergrunderstellung und schnelle Formatanpassungen."
          },
          {
            q: "Können Sie Content für technische oder Nischen-Branchen produzieren?",
            a: "Ja. Unser Team ist darauf spezialisiert, komplexe Themen – von SaaS-Infrastruktur bis hin zu politischer Kommunikation – in klare visuelle Geschichten zu übersetzen."
          },
          {
            q: "Wie lange ist die typische Vorlaufzeit?",
            a: "Content-Sprints dauern in der Regel 2-4 Wochen von Konzept bis zum finalen Asset. Größere Markenfilme oder System-Updates laufen meist in 6-8 Wochen-Zyklen."
          }
        ].map(item => (
          <div class="rounded-xl border border-zinc-800 bg-zinc-900/40 p-6">
            <h3 class="mb-3 font-semibold text-zinc-200">{item.q}</h3>
            <p class="text-sm text-zinc-400 leading-relaxed">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="px-6 py-24 text-center">
    <div class="mx-auto max-w-4xl rounded-3xl bg-gradient-to-br from-cyan-400/20 to-violet-400/20 p-12 md:p-24 border border-zinc-800" data-animation="scale">
      <h2 class="mb-6 text-3xl font-bold md:text-5xl tracking-tight">Bereit, Ihre Geschichte zu visualisieren?</h2>
      <p class="mx-auto mb-10 max-w-xl text-lg text-zinc-300">
        Sprechen Sie mit unseren Senior-Partnern über Ihren Bedarf. Wir schlagen eine realistische Roadmap vor, kein bloßes Moodboard.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/de/contact"
          class="rounded-lg bg-cyan-400 px-8 py-4 font-semibold text-zinc-950 transition-colors hover:bg-cyan-300"
        >
          Projekt-Call buchen
        </a>
        <a
          href="mailto:hola@ai-native.es"
          class="rounded-lg border border-zinc-700 bg-zinc-950 px-8 py-4 text-zinc-300 transition-colors hover:border-cyan-400/50"
        >
          E-Mail senden
        </a>
      </div>
    </div>
  </section>
</Layout>
