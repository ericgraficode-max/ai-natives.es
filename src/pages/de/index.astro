---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import { getHero, getServices, getProjects, isSanityConfigured } from '../lib/sanity';
import { urlFor } from '../lib/sanityImage';

const hero = await getHero();
const services = await getServices();
const projects = await getProjects();
const hasSanity = isSanityConfigured();

// Fallback content
const heroData = hero || {
  headline: 'Wir bauen digitale Erlebnisse, die zählen',
  subheadline:
    'Von der Strategie bis zur Umsetzung helfen wir Marken, durch durchdachtes Design und modernste Technologie mit Menschen in Kontakt zu treten.',
  image: null,
  video: null,
};
---

<Layout
  lang="de"
  title="AI‑Native.es | Digital Product, Growth & Creative Studio"
  description="Ein Senior-Team für Produktdesign, Growth und Engineering, das internationale Erfahrung in den spanischen Markt einbringt."
>
  <!-- Hero -->
  <header class="relative flex min-h-screen items-center justify-center overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-zinc-900 via-zinc-950 to-zinc-950" />
    <div class="absolute inset-0 opacity-30">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-cyan-500/20 rounded-full blur-3xl animate-pulse" />
      <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-violet-500/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s" />
    </div>
    
    <div class="relative z-10 max-w-5xl mx-auto px-6 text-center">
      <h1
        class="mb-6 text-4xl font-bold tracking-tight md:text-6xl lg:text-7xl font-[family-name:var(--font-syne)]"
        data-animation="fade-up"
      >
        <span class="bg-gradient-to-r from-cyan-300 via-sky-400 to-violet-400 bg-clip-text text-transparent">
          AI‑native digital growth
        </span>
      </h1>
      <p class="mx-auto mb-12 max-w-2xl text-lg text-zinc-300 md:text-xl" data-animation="fade-up">
        AI‑Native.es wird von einem Senior Product Lead und einem AI‑native CTO geleitet – mit Erfahrung bei Vodafone, 
        eBay, flaconi und anderen europäischen Playern. Kein Fluff, kein AI-Slop – nur ein Senior-Team, das Ergebnisse liefert.
      </p>
      <div class="flex flex-wrap gap-4 justify-center" data-animation="fade-up">
        <a
          href="/de/contact"
          class="rounded-lg bg-cyan-400 px-8 py-4 font-semibold text-zinc-950 transition-colors hover:bg-cyan-300"
        >
          Projekt-Call buchen
        </a>
        <a
          href="/de/services"
          class="rounded-lg border border-zinc-600 px-8 py-4 text-zinc-300 transition-colors hover:border-cyan-400 hover:text-cyan-300"
        >
          Unsere Leistungen
        </a>
      </div>
    </div>
  </header>

  <!-- Services -->
  <section id="services" class="px-6 py-24">
    <div class="max-w-6xl mx-auto">
      <h2 class="mb-4 text-center text-3xl font-bold md:text-5xl" data-animation="fade-up">
        Senior Köpfe, schlanke Teams
      </h2>
      <p class="mx-auto mb-16 max-w-2xl text-center text-zinc-400" data-animation="fade-up">
        Wir bewegen uns an der Schnittstelle von Produktdesign, Growth und Engineering. Jedes Projekt wird vom AI‑Native.es 
        Kernteam geleitet, unterstützt von einem internationalen Netzwerk aus Experten.
      </p>
      <div class="grid gap-8 md:grid-cols-3">
        <a
          href="/de/services/user-interface-user-research"
          class="group rounded-2xl border border-zinc-800 bg-zinc-900/50 p-8 transition-colors hover:border-cyan-400/60"
          data-animation="fade-up"
        >
          <div
            class="mb-6 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-cyan-400/30 to-violet-400/30 text-2xl"
          >
            ◇
          </div>
          <h3 class="mb-3 text-xl font-semibold">User Interface & Research</h3>
          <p class="text-sm text-zinc-400">
            Product Discovery, UX-Strategie und Interface-Design, das auf echten Nutzerbedürfnissen basiert.
          </p>
        </a>
        <a
          href="/de/services/european-accessibility-compliance"
          class="group rounded-2xl border border-zinc-800 bg-zinc-900/50 p-8 transition-colors hover:border-cyan-400/60"
          data-animation="fade-up"
        >
          <div
            class="mb-6 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-cyan-400/30 to-violet-400/30 text-2xl"
          >
            ☑
          </div>
          <h3 class="mb-3 text-xl font-semibold">Accessibility Audits</h3>
          <p class="text-sm text-zinc-400">
            WCAG und EAA-Vorbereitung für Teams, die eine klare und pragmatische Roadmap benötigen.
          </p>
        </a>
        <a
          href="/de/services/conversion-optimization"
          class="group rounded-2xl border border-zinc-800 bg-zinc-900/50 p-8 transition-colors hover:border-cyan-400/60"
          data-animation="fade-up"
        >
          <div
            class="mb-6 inline-flex h-12 w-12 items-center justify-center rounded-xl bg-gradient-to-br from-cyan-400/30 to-violet-400/30 text-2xl"
          >
            ↑
          </div>
          <h3 class="mb-3 text-xl font-semibold">Conversion Optimierung</h3>
          <p class="text-sm text-zinc-400">
            Strukturierte Experimente und CRO-Programme, die jedes Uplift direkt mit Umsatz und EBITDA verknüpfen.
          </p>
        </a>
      </div>
    </div>
  </section>

  <!-- Contact teaser -->
  <section id="contact" class="px-6 py-24">
    <div class="max-w-xl mx-auto">
      <h2 class="mb-4 text-center text-3xl font-bold md:text-5xl" data-animation="fade-up">Let’s talk</h2>
      <p class="mb-8 text-center text-zinc-400" data-animation="fade-up">
        Zwei Senior-Partner in jedem Call, keine Account-Manager. Sagen Sie uns, wo Sie hin wollen – wir zeigen Ihnen den Weg.
      </p>
      <div class="space-y-8" data-animation="fade-up">
        <ContactForm />
        <p class="text-center text-xs text-zinc-500">
          Lieber per E-Mail? Schreiben Sie uns an{' '}
          <a href="mailto:hola@ai-native.es" class="text-cyan-300 hover:text-cyan-200">hola@ai-native.es</a>
        </p>
      </div>
    </div>
  </section>

</Layout>
