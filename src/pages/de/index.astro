---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';
import { ChevronRight } from '../../components/FeatherIcons.ts';
import HeroAnimation from '../../components/HeroAnimation.astro';

const services = [
  {
    title: 'UI & User Research',
    simple: 'Wir gestalten Apps und Websites, die Nutzer lieben und die den Kaufprozess vereinfachen.',
    icon: '✨',
    link: '/de/services/user-interface-user-research'
  },
  {
    title: 'Conversion Optimierung',
    simple: 'Wir finden die Schwachstellen Ihrer Website und beheben sie, um Ihren Umsatz nachhaltig zu steigern.',
    icon: '📈',
    link: '/de/services/conversion-optimization'
  },
  {
    title: 'Accessibility Audits',
    simple: 'Wir stellen sicher, dass Ihre Seite rechtskonform und für alle nutzbar ist – Schutz vor Bußgeldern inklusive.',
    icon: '♿',
    link: '/de/services/european-accessibility-compliance'
  },
  {
    title: 'Digitale Fotos & Video',
    simple: 'Wir erstellen Premium-Content, der Ihr Produkt besser erklärt als tausend Worte.',
    icon: '📸',
    link: '/de/services/digital-photoshoots-video'
  },
  {
    title: 'Pricing Compliance',
    simple: 'Wir helfen Ihnen bei der Umsetzung der EU-Preisrichtlinien, ohne die Verkaufspsychologie zu opfern.',
    icon: '⚖️',
    link: '/de/services/european-pricing-compliance'
  },
  {
    title: 'Performance Marketing',
    simple: 'Wir optimieren Ihre Google Ads für maximale Sales bei jedem investierten Euro.',
    icon: '🎯',
    link: '/de/services/sea-performance-marketing'
  }
];

const team = [
  { name: 'Eric', role: 'Product & Design', avatar: '/Eric_Martinez.jpg' },
  { name: 'Victor', role: 'AI-Native CTO', avatar: '/Victor_Arias.jpg' }
];
---

<Layout
  lang="de"
  title="Hound | ai-native | High-Performance Digital Growth Studio"
  description="Senior-geführtes Produktdesign, Growth und Engineering. Wir sind die Growth Hunters für Marken mit internationalen Ambitionen."
>
  <!-- Hero Section -->
  <header class="relative flex min-h-screen items-center justify-center overflow-hidden px-6 pt-20">
    <HeroAnimation />
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-cyan-500/50 to-transparent"></div>
    
    <div class="relative z-10 max-w-6xl mx-auto text-center">
      <div class="mb-8 inline-flex items-center gap-3 rounded-full border border-cyan-400/20 bg-zinc-950/80 px-4 py-2 text-xs font-bold uppercase tracking-widest text-cyan-400" data-animation="fade-up">
        <span class="flex h-2 w-2 rounded-full bg-cyan-500 animate-pulse"></span>
        Gestatten: Hound | ai-native
      </div>
      
      <h1 class="mb-8 text-6xl font-black tracking-tighter md:text-8xl lg:text-9xl leading-[0.9]" data-animation="fade-up">
        Auf der Jagd nach <br/><span class="italic text-zinc-400">Wachstum.</span><br/>
        <span class="bg-gradient-to-r from-cyan-300 via-sky-400 to-violet-400 bg-clip-text text-transparent">Präzision im Output.</span>
      </h1>
      
      <p class="mx-auto mb-12 max-w-2xl text-xl text-zinc-400 font-medium md:text-2xl" data-animation="fade-up">
        Ihre Konkurrenz hat Agenturen. Sie haben Hounds. Senior-Expertise von eBay, Vodafone und Flaconi – fokussiert auf eine Sache: Ihre Zahlen zu bewegen.
      </p>
      
      <div class="flex flex-wrap items-center justify-center gap-6" data-animation="fade-up">
        <a href="/de/contact" class="group relative inline-flex items-center gap-2 overflow-hidden rounded-2xl bg-cyan-400 px-10 py-5 font-black text-zinc-950 transition-all hover:bg-cyan-300 hover:scale-105 active:scale-95">
          Jagd starten
          <span class="transition-transform group-hover:translate-x-1" set:html={ChevronRight}></span>
        </a>
        <a href="javascript:void(0)" style="display:none" class="rounded-2xl border border-zinc-800 bg-zinc-900/50 px-10 py-5 font-bold text-zinc-300 transition-colors hover:border-cyan-400/50 hover:text-cyan-300">
          Unsere Story
        </a>
      </div>
    </div>
    
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce opacity-20">
      <div class="h-10 w-px bg-gradient-to-b from-cyan-400 to-transparent"></div>
    </div>
  </header>

  <!-- The Origin: Von Riesen zu Jägern -->
  <section  class="relative border-y border-zinc-900 bg-zinc-950 px-6 py-32 overflow-hidden">
    <div class="absolute -right-24 top-1/4 h-96 w-96 bg-cyan-500/5 blur-[120px] rounded-full"></div>
    
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-20 lg:grid-cols-2 items-center">
        <div data-animation="fade-up">
          <p class="mb-4 text-xs font-bold uppercase tracking-[0.4em] text-cyan-500">Wie alles begann</p>
          <h2 class="mb-8 text-5xl font-bold tracking-tight md:text-7xl leading-tight text-white">
            Wir haben die <span class="text-zinc-600">Konzernriesen</span> verlassen, um schneller zu bauen.
          </h2>
          <div class="space-y-8 text-lg text-zinc-400 leading-relaxed">
            <p>
              Nach einem Jahrzehnt in Führungspositionen bei <span class="text-white font-bold">eBay, Vodafone und Flaconi</span> sahen wir ein immer gleiches Muster: Unternehmen verschwenden Millionen für "große Agenturen", in denen Senior-Partner Träume verkaufen, aber Junioren die Arbeit machen.
            </p>
            <p>
              Wir haben <span class="text-cyan-400 font-bold italic">Hound</span> gegründet, um das zu ändern. Keine Account-Manager. Keine Junioren, die auf Ihr Budget lernen. Nur ein schlankes Team aus krisenerprobten Seniors, die in jeder Zeile Code und jedem Pixel nach Effizienz und Wachstum jagen.
            </p>
          </div>
        </div>
        
        <div class="relative" data-animation="scale">
          <div class="absolute -inset-4 rounded-[3rem] bg-gradient-to-tr from-cyan-500/20 to-violet-500/20 blur-2xl opacity-40"></div>
          <div class="relative rounded-[2.5rem] border border-zinc-800 bg-zinc-900/60 p-12 backdrop-blur-xl">
             <div class="flex gap-4 mb-8">
                {team.map(member => (
                  <div class="relative group">
                    <img src={member.avatar} alt={member.name} class="h-20 w-20 rounded-2xl grayscale group-hover:grayscale-0 transition-all duration-500 border border-zinc-700 group-hover:border-cyan-400/50" />
                    <div class="absolute -bottom-2 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-lg bg-cyan-400 px-2 py-0.5 text-[10px] font-black text-zinc-950 opacity-0 group-hover:opacity-100 transition-opacity">
                      {member.name}
                    </div>
                  </div>
                ))}
             </div>
            <p class="mb-8 text-2xl font-medium text-zinc-200 leading-tight">
              "Wir präsentieren nicht nur und delegieren dann. Wir auditieren, designen und liefern. Wir sind Hounds, weil wir erst aufhören, wenn das Ergebnis steht."
            </p>
            <div class="flex items-center gap-4 border-t border-zinc-800 pt-8">
              <div>
                <p class="text-sm font-black text-cyan-400 uppercase tracking-widest">Die Core Squad</p>
                <p class="text-xs text-zinc-500">Eric Martinez Solis & Victor</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The USP: Das Gegenmittel -->
  <section class="px-6 py-32 bg-zinc-950">
     <div class="mx-auto max-w-6xl">
        <div class="mb-20 text-center" data-animation="fade-up">
           <h2 class="text-4xl font-black md:text-6xl tracking-tighter mb-4">Warum wir <span class="text-cyan-400 italic">anders</span> sind.</h2>
           <p class="text-zinc-500 max-w-xl mx-auto uppercase tracking-widest text-xs font-bold">Der Hound Standard</p>
        </div>
        
        <div class="grid gap-8 md:grid-cols-3">
           <div class="group rounded-3xl border border-zinc-800 bg-zinc-900/20 p-10 hover:border-cyan-400/30 transition-all" data-animation="fade-up">
              <div class="mb-6 text-3xl">🛡️</div>
              <h3 class="text-xl font-bold mb-4 text-white">Nur Senior-Experten</h3>
              <p class="text-zinc-400 text-sm leading-relaxed">Sie sprechen direkt mit den Machern. Keine Account-Manager, kein "Stille Post"-Prinzip. Direkter Zugang zu Elite-Talent.</p>
           </div>
           <div class="group rounded-3xl border border-zinc-800 bg-zinc-900/20 p-10 hover:border-violet-400/30 transition-all" data-animation="fade-up">
              <div class="mb-6 text-3xl">⚡</div>
              <h3 class="text-xl font-bold mb-4 text-white">AI-Native Speed</h3>
              <p class="text-zinc-400 text-sm leading-relaxed">Wir nutzen KI für das "Boring Stuff" – so liefern wir High-Fidelity Ergebnisse in Wochen, wofür andere Monate brauchen.</p>
           </div>
           <div class="group rounded-3xl border border-zinc-800 bg-zinc-900/20 p-10 hover:border-cyan-400/30 transition-all" data-animation="fade-up">
              <div class="mb-6 text-3xl">🌎</div>
              <h3 class="text-xl font-bold mb-4 text-white">Intl. Standards</h3>
              <p class="text-zinc-400 text-sm leading-relaxed">Ansässig in Spanien und Berlin, bringen wir die Strenge von 100M€+ Plattformen in jedes Projekt ein.</p>
           </div>
        </div>
     </div>
  </section>

  <!-- Services: Die Hebel -->
  <section id="services" class="px-6 py-32 border-t border-zinc-900">
    <div class="mx-auto max-w-6xl">
      <div class="mb-24" data-animation="fade-up">
        <h2 class="mb-4 text-5xl font-black md:text-7xl tracking-tighter">Wachstums-<span class="text-zinc-600 italic">Hebel.</span></h2>
        <p class="max-w-2xl text-lg text-zinc-400">Spezifische, hochwirksame Interventionen, um Engpässe zu lösen und Ihren digitalen Motor zu beschleunigen.</p>
      </div>

      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {services.map(service => (
          <a href={service.link} class="group relative overflow-hidden rounded-[2rem] border border-zinc-800 bg-zinc-900/20 p-10 transition-all hover:border-cyan-400/40 hover:bg-zinc-900/40" data-animation="fade-up">
            <div class="mb-8 inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-zinc-800 text-4xl transition-transform group-hover:scale-110 group-hover:rotate-6">
              {service.icon}
            </div>
            <h3 class="mb-4 text-2xl font-black group-hover:text-cyan-300 transition-colors tracking-tight">{service.title}</h3>
            <p class="mb-10 text-zinc-500 leading-relaxed font-medium">{service.simple}</p>
            <div class="flex items-center gap-2 text-xs font-black uppercase tracking-widest text-cyan-400 opacity-0 transition-all group-hover:opacity-100 group-hover:translate-x-2">
              Hebel erkunden <span class="h-4 w-4" set:html={ChevronRight}></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="px-6 py-32">
    <div class="mx-auto max-w-5xl rounded-[3rem] bg-gradient-to-br from-cyan-400/10 via-zinc-950 to-zinc-950 p-12 text-center md:p-24 border border-zinc-800/50 relative overflow-hidden" data-animation="scale">
      <div class="absolute -top-24 -left-24 h-96 w-96 bg-cyan-500/10 blur-[120px] rounded-full"></div>
      
      <div class="relative z-10">
         <h2 class="mb-8 text-5xl font-black md:text-8xl tracking-tighter leading-none">Bereit, die Nadel zu <br/><span class="text-cyan-400 italic">bewegen?</span></h2>
         <p class="mx-auto mb-12 max-w-xl text-xl text-zinc-400 font-medium">
           Geben Sie sich nicht mit "gut genug" zufrieden. Arbeiten Sie mit Seniors, die die Arbeit wirklich machen. Die Jagd beginnt hier.
         </p>
         <div class="flex flex-wrap justify-center gap-6">
           <a href="/de/contact" class="rounded-2xl bg-cyan-400 px-12 py-6 font-black text-zinc-950 transition-all hover:bg-cyan-300 hover:scale-105 active:scale-95">
             Strategie-Call buchen
           </a>
           <a href="mailto:hola@ai-native.es" class="rounded-2xl border border-zinc-700 bg-zinc-950 px-12 py-6 font-bold text-zinc-300 transition-colors hover:border-cyan-400/50">
             Direkte E-Mail
           </a>
         </div>
      </div>
    </div>
  </section>

</Layout>
