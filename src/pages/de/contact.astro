---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';
import { ChevronRight } from '../../components/FeatherIcons.ts';
---

<Layout
  lang="de"
  title="Kontakt | Hound | ai-native"
  description="Sprechen Sie direkt mit den Senior-Partnern über Ihre Wachstumsziele. Keine Account-Manager, nur Ergebnisse."
>
  <section class="relative min-h-screen px-6 pb-20 pt-16 md:pt-24 overflow-hidden">
    <!-- Dekorativer Hintergrund -->
    <div class="absolute inset-0 -z-10">
      <div class="absolute top-0 right-0 h-[500px] w-[500px] bg-cyan-500/10 blur-[120px] rounded-full translate-x-1/2 -translate-y-1/2"></div>
      <div class="absolute bottom-0 left-0 h-[500px] w-[500px] bg-violet-500/10 blur-[120px] rounded-full -translate-x-1/2 translate-y-1/2"></div>
    </div>

    <div class="mx-auto max-w-6xl">
      <div class="grid gap-16 lg:grid-cols-[1fr,1.2fr] items-start">
        <div data-animation="fade-up">
          <p class="mb-4 text-xs font-semibold uppercase tracking-[0.3em] text-cyan-300">
            Kontakt
          </p>
          <h1 class="mb-8 text-5xl font-bold tracking-tight md:text-7xl">
            Bauen wir <br/><span class="text-zinc-500 italic">die Zukunft.</span>
          </h1>
          <p class="mb-12 max-w-md text-lg text-zinc-400">
            Erzählen Sie uns von Ihrem Projekt. Ob strukturelles Audit, Design-Sprint oder Aufbau einer Growth-Engine – wir sind bereit.
          </p>

          <div class="space-y-8">
            <div class="flex gap-6">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-zinc-900 border border-zinc-800 text-xl">🤝</div>
              <div>
                <h3 class="font-bold text-zinc-200">Nur Senior-Partner</h3>
                <p class="text-sm text-zinc-500">Sie sprechen immer mit Eric oder Victor. Keine Zwischenhändler, keine Junioren.</p>
              </div>
            </div>
            <div class="flex gap-6">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-zinc-900 border border-zinc-800 text-xl">⚡</div>
              <div>
                <h3 class="font-bold text-zinc-200">Schnelle Antwort</h3>
                <p class="text-sm text-zinc-500">Wir antworten auf ernsthafte Anfragen innerhalb von 24 Stunden.</p>
              </div>
            </div>
            <div class="flex gap-6">
              <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-2xl bg-zinc-900 border border-zinc-800 text-xl">📍</div>
              <div>
                <h3 class="font-bold text-zinc-200">Berlin & Spanien</h3>
                <p class="text-sm text-zinc-500">Internationale Standards mit lokalem Fokus.</p>
              </div>
            </div>
          </div>

          <div class="mt-16 pt-16 border-t border-zinc-900">
             <p class="text-xs text-zinc-500 mb-2 uppercase tracking-widest">Direkter Kanal</p>
             <a href="mailto:hola@ai-native.es" class="text-2xl font-bold text-cyan-400 hover:text-cyan-300 transition-colors">
                hola@ai-native.es
             </a>
          </div>
        </div>

        <div class="relative" data-animation="fade-up">
           <div class="absolute -inset-1 bg-gradient-to-r from-cyan-500 to-violet-500 rounded-[2.5rem] blur opacity-20"></div>
           <div class="relative bg-zinc-950 border border-zinc-800 rounded-[2rem] p-8 md:p-12 shadow-2xl">
              <h2 class="mb-8 text-2xl font-bold">Gespräch starten</h2>
              <ContactForm />
              <p class="mt-8 text-center text-[10px] text-zinc-500 leading-relaxed uppercase tracking-tighter">
                 Mit dem Absenden dieses Formulars erklären Sie sich damit einverstanden, dass unser Senior-Team Ihre Daten prüft, um eine strategische Antwort zu geben.
              </p>
           </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
