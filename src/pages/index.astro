---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import { ChevronRight } from '../components/FeatherIcons.ts';
import HeroAnimation from '../components/HeroAnimation.astro';

const services = [
  {
    title: 'UI & User Research',
    simple: 'We design apps and websites that people actually enjoy using, making it easy for them to buy from you.',
    icon: '✨',
    link: '/services/user-interface-user-research'
  },
  {
    title: 'Conversion Optimization',
    simple: 'We find the "leaks" in your website where you lose customers and fix them to increase your revenue.',
    icon: '📈',
    link: '/services/conversion-optimization'
  },
  {
    title: 'Accessibility Audits',
    simple: 'We ensure your site is legal and usable for everyone, protecting you from fines and reaching more people.',
    icon: '♿',
    link: '/services/european-accessibility-compliance'
  },
  {
    title: 'Digital Photos & Video',
    simple: 'We create premium visuals that explain your product better than words ever could.',
    icon: '📸',
    link: '/services/digital-photoshoots-video'
  },
  {
    title: 'Pricing Compliance',
    simple: 'We help you navigate European discount laws so you stay legal without losing your "sale" appeal.',
    icon: '⚖️',
    link: '/services/european-pricing-compliance'
  },
  {
    title: 'Performance Marketing',
    simple: 'We optimize your Google Ads to make sure you get the most sales for every euro you spend.',
    icon: '🎯',
    link: '/services/sea-performance-marketing'
  }
];

const team = [
  { name: 'Eric', role: 'Product & Design', avatar: 'https://unavatar.io/twitter/ericsolis' },
  { name: 'Victor', role: 'AI-Native CTO', avatar: 'https://unavatar.io/github/vgm' }
];
---

<Layout
  title="Hound | ai-native | High-Performance Digital Growth Studio"
  description="Senior-led product design, growth, and engineering. We are the growth hunters for Spanish brands with international ambitions."
>
  <!-- Hero Section: The Hook -->
  <header class="section-hero relative flex min-h-screen items-center justify-center overflow-hidden px-6 pt-20">
    <HeroAnimation />
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-cyan-500/50 to-transparent"></div>
    
    <div class="relative z-10 max-w-6xl mx-auto text-center">
      <div class="hero-badge mb-8 inline-flex items-center gap-3 rounded-full border border-cyan-400/20 bg-zinc-950/80 px-4 py-2 text-xs font-bold uppercase tracking-widest text-cyan-400" data-animation="fade-up">
        <span class="flex h-2 w-2 rounded-full bg-cyan-500 animate-pulse"></span>
        Introducing Hound | ai-native
      </div>
      
      <h1 class="hero-title mb-8 text-6xl font-black tracking-tighter md:text-8xl lg:text-9xl leading-[0.9]" data-animation="fade-up">
        Hunting for <br/><span class="italic text-zinc-700">Growth.</span><br/>
        <span class="bg-gradient-to-r from-cyan-300 via-sky-400 to-violet-400 bg-clip-text text-transparent">Shipping with Precision.</span>
      </h1>
      
      <p class="hero-description mx-auto mb-12 max-w-2xl text-xl text-zinc-400 font-medium md:text-2xl" data-animation="fade-up">
        Your competitors have agencies. You have Hounds. Senior intelligence from eBay, Vodafone, and Flaconi, focused on one thing: moving your numbers.
      </p>
      
      <div class="hero-actions flex flex-wrap items-center justify-center gap-6" data-animation="fade-up">
        <a href="/contact" class="btn-primary group relative inline-flex items-center gap-2 overflow-hidden rounded-2xl bg-cyan-400 px-10 py-5 font-black text-zinc-950 transition-all hover:bg-cyan-300 hover:scale-105 active:scale-95">
          Start the Hunt
          <span class="transition-transform group-hover:translate-x-1" set:html={ChevronRight}></span>
        </a>
        <a href="#origin" class="btn-secondary rounded-2xl border border-zinc-800 bg-zinc-900/50 px-10 py-5 font-bold text-zinc-300 transition-colors hover:border-cyan-400/50 hover:text-cyan-300">
          Our Story
        </a>
      </div>
    </div>
    
    <div class="hero-scroll-indicator absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce opacity-20">
      <div class="h-10 w-px bg-gradient-to-b from-cyan-400 to-transparent"></div>
    </div>
  </header>

  <!-- The Origin: From Giants to Hunters -->
  <section id="origin" class="section-origin relative border-y border-zinc-900 bg-zinc-950 px-6 py-32 overflow-hidden">
    <div class="absolute -right-24 top-1/4 h-96 w-96 bg-cyan-500/5 blur-[120px] rounded-full"></div>
    
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-20 lg:grid-cols-2 items-center">
        <div class="origin-content" data-animation="fade-up">
          <p class="mb-4 text-xs font-bold uppercase tracking-[0.4em] text-cyan-500">How it came to be</p>
          <h2 class="mb-8 text-5xl font-bold tracking-tight md:text-7xl leading-tight text-white">
            We left the <span class="text-zinc-600">Corporate Giants</span> to build something faster.
          </h2>
          <div class="space-y-8 text-lg text-zinc-400 leading-relaxed">
            <p>
              After a decade leading product and engineering at <span class="text-white font-bold">eBay, Vodafone, and Flaconi</span>, we saw a recurring pattern: companies wasting millions on "big agencies" where senior partners sell the dream, but juniors do the work.
            </p>
            <p>
              We founded <span class="text-cyan-400 font-bold italic">Hound</span> to fix that. No account managers. No juniors learning on your budget. Just a lean squad of battle-hardened seniors who hunt for efficiency and growth in every line of code and every pixel.
            </p>
          </div>
        </div>
        
        <div class="origin-visual relative" data-animation="scale">
          <div class="absolute -inset-4 rounded-[3rem] bg-gradient-to-tr from-cyan-500/20 to-violet-500/20 blur-2xl opacity-40"></div>
          <div class="relative rounded-[2.5rem] border border-zinc-800 bg-zinc-900/60 p-12 backdrop-blur-xl">
             <div class="flex gap-4 mb-8">
                {team.map(member => (
                  <div class="relative group">
                    <img src={member.avatar} alt={member.name} class="h-20 w-20 rounded-2xl grayscale group-hover:grayscale-0 transition-all duration-500 border border-zinc-700 group-hover:border-cyan-400/50" />
                    <div class="absolute -bottom-2 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-lg bg-cyan-400 px-2 py-0.5 text-[10px] font-black text-zinc-950 opacity-0 group-hover:opacity-100 transition-opacity">
                      {member.name}
                    </div>
                  </div>
                ))}
             </div>
            <p class="mb-8 text-2xl font-medium text-zinc-200 leading-tight">
              "We don't pitch and delegate. We audit, design, and ship. We are Hounds because we don't stop until we find the result."
            </p>
            <div class="flex items-center gap-4 border-t border-zinc-800 pt-8">
              <div>
                <p class="text-sm font-black text-cyan-400 uppercase tracking-widest">The Core Squad</p>
                <p class="text-xs text-zinc-500">Eric Martinez Solis & Victor</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The USP: The Antidote -->
  <section class="section-usp px-6 py-32 bg-zinc-950">
     <div class="mx-auto max-w-6xl">
        <div class="usp-header mb-20 text-center" data-animation="fade-up">
           <h2 class="text-4xl font-black md:text-6xl tracking-tighter mb-4">Why we are <span class="text-cyan-400 italic">different.</span></h2>
           <p class="text-zinc-500 max-w-xl mx-auto uppercase tracking-widest text-xs font-bold">The Hound Standard</p>
        </div>
        
        <div class="usp-grid grid gap-8 md:grid-cols-3">
           <div class="usp-card group rounded-3xl border border-zinc-800 bg-zinc-900/20 p-10 hover:border-cyan-400/30 transition-all" data-animation="fade-up">
              <div class="mb-6 text-3xl">🛡️</div>
              <h3 class="text-xl font-bold mb-4 text-white">Senior-Only Squad</h3>
              <p class="text-zinc-400 text-sm leading-relaxed">You talk to the people who build. No account managers, no game of telephone. Direct access to elite talent.</p>
           </div>
           <div class="usp-card group rounded-3xl border border-zinc-800 bg-zinc-900/20 p-10 hover:border-violet-400/30 transition-all" data-animation="fade-up">
              <div class="mb-6 text-3xl">⚡</div>
              <h3 class="text-xl font-bold mb-4 text-white">AI-Native Velocity</h3>
              <p class="text-zinc-400 text-sm leading-relaxed">We use AI to automate the boring stuff, allowing us to ship high-fidelity work in weeks that takes others months.</p>
           </div>
           <div class="usp-card group rounded-3xl border border-zinc-800 bg-zinc-900/20 p-10 hover:border-cyan-400/30 transition-all" data-animation="fade-up">
              <div class="mb-6 text-3xl">🌎</div>
              <h3 class="text-xl font-bold mb-4 text-white">Intl. Standards</h3>
              <p class="text-zinc-400 text-sm leading-relaxed">Based in Spain and Berlin, we bring the rigor of €100M+ European platforms to every project we touch.</p>
           </div>
        </div>
     </div>
  </section>

  <!-- Services: The Levers -->
  <section id="services" class="section-services px-6 py-32 border-t border-zinc-900">
    <div class="mx-auto max-w-6xl">
      <div class="services-header mb-24" data-animation="fade-up">
        <h2 class="mb-4 text-5xl font-black md:text-7xl tracking-tighter">Growth <span class="text-zinc-600 italic">Levers.</span></h2>
        <p class="max-w-2xl text-lg text-zinc-400">Specific, high-impact interventions designed to solve bottlenecks and accelerate your digital engine.</p>
      </div>

      <div class="services-grid grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {services.map(service => (
          <a href={service.link} class="service-card group relative overflow-hidden rounded-[2rem] border border-zinc-800 bg-zinc-900/20 p-10 transition-all hover:border-cyan-400/40 hover:bg-zinc-900/40" data-animation="fade-up">
            <div class="mb-8 inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-zinc-800 text-4xl transition-transform group-hover:scale-110 group-hover:rotate-6">
              {service.icon}
            </div>
            <h3 class="mb-4 text-2xl font-black group-hover:text-cyan-300 transition-colors tracking-tight">{service.title}</h3>
            <p class="mb-10 text-zinc-500 leading-relaxed font-medium">{service.simple}</p>
            <div class="flex items-center gap-2 text-xs font-black uppercase tracking-widest text-cyan-400 opacity-0 transition-all group-hover:opacity-100 group-hover:translate-x-2">
              Explore Lever <span class="h-4 w-4" set:html={ChevronRight}></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA: The Summons -->
  <section class="section-cta px-6 py-32">
    <div class="cta-container mx-auto max-w-5xl rounded-[3rem] bg-gradient-to-br from-cyan-400/10 via-zinc-950 to-zinc-950 p-12 text-center md:p-24 border border-zinc-800/50 relative overflow-hidden" data-animation="scale">
      <div class="absolute -top-24 -left-24 h-96 w-96 bg-cyan-500/10 blur-[120px] rounded-full"></div>
      
      <div class="relative z-10">
         <h2 class="mb-8 text-5xl font-black md:text-8xl tracking-tighter leading-none">Ready to <br/><span class="text-cyan-400 italic">move the needle?</span></h2>
         <p class="mx-auto mb-12 max-w-xl text-xl text-zinc-400 font-medium">
           Stop settling for "good enough". Hire the seniors who will actually do the work. The hunt starts here.
         </p>
         <div class="cta-actions flex flex-wrap justify-center gap-6">
           <a href="/contact" class="btn-primary rounded-2xl bg-cyan-400 px-12 py-6 font-black text-zinc-950 transition-all hover:bg-cyan-300 hover:scale-105 active:scale-95">
             Book a Strategy Call
           </a>
           <a href="mailto:hola@ai-native.es" class="btn-secondary rounded-2xl border border-zinc-700 bg-zinc-950 px-12 py-6 font-bold text-zinc-300 transition-colors hover:border-cyan-400/50">
             Direct Email
           </a>
         </div>
      </div>
    </div>
  </section>
</Layout>
