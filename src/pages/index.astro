---
import Layout from '../layouts/Layout.astro';
import ContactForm from '../components/ContactForm.astro';
import { ChevronRight } from '../components/FeatherIcons.ts';

const services = [
  {
    title: 'User Interface & Research',
    simple: 'We design apps and websites that people actually enjoy using, making it easy for them to buy from you.',
    icon: '✨',
    link: '/services/user-interface-user-research'
  },
  {
    title: 'Conversion Optimization',
    simple: 'We find the "leaks" in your website where you lose customers and fix them to increase your revenue.',
    icon: '📈',
    link: '/services/conversion-optimization'
  },
  {
    title: 'Accessibility Audits',
    simple: 'We ensure your site is legal and usable for everyone, protecting you from fines and reaching more people.',
    icon: '♿',
    link: '/services/european-accessibility-compliance'
  },
  {
    title: 'Digital Photos & Video',
    simple: 'We create premium visuals that explain your product better than words ever could.',
    icon: '📸',
    link: '/services/digital-photoshoots-video'
  },
  {
    title: 'Pricing Compliance',
    simple: 'We help you navigate European discount laws so you stay legal without losing your "sale" appeal.',
    icon: '⚖️',
    link: '/services/european-pricing-compliance'
  },
  {
    title: 'Performance Marketing',
    simple: 'We optimize your Google Ads to make sure you get the most sales for every euro you spend.',
    icon: '🎯',
    link: '/services/sea-performance-marketing'
  }
];
---

<Layout
  title="AI‑Native.es | High-Performance Digital Growth Studio"
  description="Senior-led product design, growth, and engineering. We build digital experiences that move numbers."
>
  <!-- Hero Section -->
  <header class="relative flex min-h-[90vh] items-center justify-center overflow-hidden px-6 pt-20">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(16,185,129,0.05),transparent)] opacity-50"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-cyan-500/50 to-transparent"></div>
    
    <div class="relative z-10 max-w-5xl mx-auto text-center">
      <div class="mb-8 inline-flex items-center gap-2 rounded-full border border-cyan-400/20 bg-cyan-400/10 px-4 py-1.5 text-xs font-semibold text-cyan-300" data-animation="fade-up">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-cyan-500"></span>
        </span>
        Senior-led. Result-driven. No fluff.
      </div>
      
      <h1 class="mb-6 text-5xl font-bold tracking-tight md:text-7xl lg:text-8xl" data-animation="fade-up">
        We build digital products that <span class="bg-gradient-to-r from-cyan-300 via-sky-400 to-violet-400 bg-clip-text text-transparent">move the needle.</span>
      </h1>
      
      <p class="mx-auto mb-10 max-w-2xl text-lg text-zinc-400 md:text-xl" data-animation="fade-up">
        Stop guessing. We bring international experience from eBay, Vodafone, and Flaconi to help Spanish brands scale with precision and senior-level craftsmanship.
      </p>
      
      <div class="flex flex-wrap items-center justify-center gap-4" data-animation="fade-up">
        <a href="/contact" class="rounded-xl bg-cyan-400 px-8 py-4 font-bold text-zinc-950 transition-all hover:bg-cyan-300 hover:scale-105 active:scale-95">
          Start a project
        </a>
        <a href="#services" class="rounded-xl border border-zinc-800 bg-zinc-900/50 px-8 py-4 font-semibold text-zinc-300 transition-colors hover:border-cyan-400/50 hover:text-cyan-300">
          See how we help
        </a>
      </div>
    </div>
  </header>

  <!-- The "Why" Section -->
  <section class="border-y border-zinc-900 bg-zinc-950/50 px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-16 lg:grid-cols-2 items-center">
        <div data-animation="fade-up">
          <h2 class="mb-8 text-4xl font-bold leading-tight md:text-5xl">You have a growth problem. <br/><span class="text-zinc-500">We have the senior solution.</span></h2>
          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-red-500/10 text-red-500">✕</div>
              <div>
                <h4 class="font-semibold text-zinc-200">The "Agency" Trap</h4>
                <p class="text-sm text-zinc-400">Junior teams learning on your budget, slow feedback loops, and cookie-cutter designs.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-green-500/10 text-green-500">✓</div>
              <div>
                <h4 class="font-semibold text-zinc-200">The AI-Native Approach</h4>
                <p class="text-sm text-zinc-400">Two senior partners on every call. High-fidelity work shipped in weeks, not months. Data-driven logic.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="relative" data-animation="scale">
          <div class="absolute -inset-4 rounded-3xl bg-gradient-to-tr from-cyan-500/20 to-violet-500/20 blur-2xl opacity-30"></div>
          <div class="relative rounded-2xl border border-zinc-800 bg-zinc-900/40 p-8">
            <p class="mb-6 text-xl font-medium italic text-zinc-300 leading-relaxed">
              "Working with Eric and Victor felt like hiring a dedicated product team overnight. They don't just 'design'; they solve business problems with code and data."
            </p>
            <div class="flex items-center gap-4">
              <div class="h-12 w-12 rounded-full bg-zinc-800 border border-zinc-700"></div>
              <div>
                <p class="text-sm font-bold">Product Lead</p>
                <p class="text-xs text-zinc-500">Leading European Retailer</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services Grid -->
  <section id="services" class="px-6 py-32">
    <div class="mx-auto max-w-6xl">
      <div class="mb-20 text-center" data-animation="fade-up">
        <h2 class="mb-4 text-4xl font-bold md:text-6xl tracking-tight">How we move your numbers</h2>
        <p class="mx-auto max-w-2xl text-zinc-400">No jargon. Just high-impact services designed to solve specific bottlenecks in your digital journey.</p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {services.map(service => (
          <a href={service.link} class="group relative rounded-3xl border border-zinc-800 bg-zinc-900/30 p-8 transition-all hover:border-cyan-400/40 hover:bg-zinc-900/50" data-animation="fade-up">
            <div class="mb-6 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-zinc-800 text-3xl transition-transform group-hover:scale-110 group-hover:rotate-3">
              {service.icon}
            </div>
            <h3 class="mb-3 text-2xl font-bold group-hover:text-cyan-300 transition-colors">{service.title}</h3>
            <p class="mb-8 text-zinc-400 leading-relaxed">{service.simple}</p>
            <div class="flex items-center gap-2 text-sm font-bold text-cyan-400 opacity-0 transition-all group-hover:opacity-100 group-hover:translate-x-2">
              Learn more <span set:html={ChevronRight}></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="px-6 py-24">
    <div class="mx-auto max-w-4xl rounded-[2.5rem] bg-gradient-to-br from-cyan-400/20 via-violet-400/10 to-transparent p-12 text-center md:p-24 border border-zinc-800/50 overflow-hidden relative" data-animation="scale">
      <div class="absolute -top-24 -left-24 h-64 w-64 bg-cyan-500/10 blur-[100px] rounded-full"></div>
      <div class="absolute -bottom-24 -right-24 h-64 w-64 bg-violet-500/10 blur-[100px] rounded-full"></div>
      
      <h2 class="relative z-10 mb-6 text-4xl font-bold md:text-6xl tracking-tight">Ready to build something serious?</h2>
      <p class="relative z-10 mx-auto mb-10 max-w-xl text-lg text-zinc-300">
        Skip the fluff. Talk directly to the partners who will be doing the work. No account managers, just results.
      </p>
      <div class="relative z-10 flex flex-wrap justify-center gap-4">
        <a href="/contact" class="rounded-xl bg-cyan-400 px-10 py-5 font-bold text-zinc-950 transition-all hover:bg-cyan-300 hover:scale-105 active:scale-95">
          Book a Project Call
        </a>
        <a href="mailto:hola@ai-native.es" class="rounded-xl border border-zinc-700 bg-zinc-950 px-10 py-5 font-semibold text-zinc-300 transition-colors hover:border-cyan-400/50">
          Email Us Directly
        </a>
      </div>
    </div>
  </section>

</Layout>
