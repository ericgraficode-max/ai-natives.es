---
import Layout from '../../../layouts/Layout.astro';
import { ChevronRight } from '../../../components/FeatherIcons.ts';
---

<Layout
  lang="es"
  title="Sesiones de Fotos Digitales y Video | Hound | ai-native"
  description="Narración visual estratégica y producción de alta gama para marcas que necesitan simplificar la complejidad. Desde películas de campaña hasta sistemas de contenido acelerados por IA."
>
  <!-- Hero Section -->
  <section class="service-hero-section relative overflow-hidden px-6 pb-32 pt-24 md:pt-32">
    <div class="absolute inset-0 -z-10 opacity-20">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-cyan-500/20 rounded-full blur-3xl animate-pulse" />
      <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-violet-500/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s" />
    </div>

    <div class="mx-auto max-w-5xl text-center" data-animation="fade-up">
      <p class="mb-4 text-xs font-semibold uppercase tracking-[0.3em] text-cyan-300">
        Producción Visual de Alta Gama
      </p>
      <h1 class="mb-6 text-4xl font-bold tracking-tight md:text-6xl lg:text-7xl">
        Deje de lanzar contenido genérico. <span class="bg-gradient-to-r from-cyan-300 to-violet-400 bg-clip-text text-transparent">Empiece a contar historias.</span>
      </h1>
      <p class="mx-auto mb-10 max-w-3xl text-lg text-zinc-400 md:text-xl">
        La mayoría del contenido visual carece de dirección. Actuamos como su equipo de marketing extendido, traduciendo 
        la complejidad técnica en sistemas visuales claros y atractivos que viven en cada canal.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/es/contact"
          class="rounded-lg bg-cyan-400 px-8 py-4 font-semibold text-zinc-950 transition-colors hover:bg-cyan-300"
        >
          Reserve una Llamada de Producción
        </a>
        <a
          href="#proceso"
          class="rounded-lg border border-zinc-700 px-8 py-4 text-zinc-300 transition-colors hover:border-cyan-400/50 hover:text-cyan-300"
        >
          Explore Nuestro Proceso
        </a>
      </div>
    </div>
  </section>

  <!-- Value Proposition -->
  <section class="border-y border-zinc-900 bg-zinc-950/50 px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-12 lg:grid-cols-2 items-center">
        <div data-animation="fade-up">
          <h2 class="mb-6 text-3xl font-bold md:text-4xl">Narración visual para un mundo complejo</h2>
          <p class="mb-6 text-zinc-400">
            Inspirados por estudios como Visionary Berlin, no solo "hacemos fotos". Construimos identidades visuales 
            que hacen obvio el valor de su producto. Ya sea una solución B2B técnica o una marca de consumo premium, 
            encontramos el gancho visual que conecta.
          </p>
          <ul class="space-y-4">
            {[
              "Alineación estratégica con el posicionamiento de su marca",
              "Sistemas de activos multicanal (Web, Social, Impresión)",
              "Ciclos de producción de respuesta rápida",
              "Modelo híbrido: Artesanía + aceleración por IA"
            ].map(item => (
              <li class="flex items-center gap-3 text-zinc-300">
                <span class="flex h-5 w-5 items-center justify-center rounded-full bg-cyan-400/20 text-cyan-400 text-xs">✓</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="relative rounded-2xl border border-zinc-800 bg-zinc-900/40 p-8 lg:p-12" data-animation="scale">
          <div class="absolute -top-4 -right-4 h-24 w-24 rounded-full bg-violet-500/10 blur-2xl" />
          <div class="space-y-6 text-center">
             <div class="flex justify-center gap-2">
                <div class="h-2 w-8 rounded-full bg-cyan-400"></div>
                <div class="h-2 w-8 rounded-full bg-zinc-800"></div>
                <div class="h-2 w-8 rounded-full bg-zinc-800"></div>
             </div>
             <p class="text-xl font-medium text-zinc-200">"No solo entregaron un video; entregaron una estrategia visual que redefinió nuestra presencia en redes sociales."</p>
             <div class="pt-4 border-t border-zinc-800">
                <p class="text-xs font-bold uppercase tracking-widest text-cyan-300">Director Creativo</p>
                <p class="text-[10px] text-zinc-500">Scale-up Europea</p>
             </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Methodology Section -->
  <section id="proceso" class="px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16 text-center" data-animation="fade-up">
        <h2 class="mb-4 text-3xl font-bold md:text-5xl">El Ciclo de Producción</h2>
        <p class="mx-auto max-w-2xl text-zinc-400">
          Combinamos la dirección creativa tradicional con herramientas técnicas modernas para lanzar 
          visuales de alto impacto a la velocidad del comercio digital.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
        {[
          {
            step: "01",
            title: "Estrategia",
            desc: "Nos sumergimos en la lógica de su producto para identificar los mensajes visuales clave que generan confianza.",
            icon: "🧠"
          },
          {
            step: "02",
            title: "Concepto",
            desc: "Storyboards, moodboards y listas de tomas diseñadas para la consistencia entre canales.",
            icon: "🎨"
          },
          {
            step: "03",
            title: "Producción",
            desc: "Creación en el set o digital-first utilizando equipos de cine y fotografía de alta gama.",
            icon: "🎬"
          },
          {
            step: "04",
            title: "Iteración",
            desc: "Generación de variantes asistida por IA y escalado para asegurar que cada formato esté optimizado.",
            icon: "🔄"
          }
        ].map(item => (
          <div class="group relative rounded-2xl border border-zinc-800 bg-zinc-900/30 p-8 transition-colors hover:border-cyan-400/40" data-animation="fade-up">
            <span class="absolute top-4 right-6 text-4xl font-black text-zinc-800/50 transition-colors group-hover:text-cyan-400/10">{item.step}</span>
            <div class="mb-6 text-3xl">{item.icon}</div>
            <h3 class="mb-3 text-xl font-semibold">{item.title}</h3>
            <p class="text-sm text-zinc-400 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Creative Middle Section -->
  <section class="bg-gradient-to-b from-zinc-950 to-zinc-900 px-6 py-24 overflow-hidden">
    <div class="mx-auto max-w-6xl">
      <div class="rounded-3xl border border-violet-400/20 bg-violet-950/5 p-8 md:p-16 lg:flex items-center gap-16" data-animation="fade-up">
        <div class="lg:w-1/2">
          <div class="mb-6 inline-flex rounded-full bg-violet-400/10 px-4 py-1 text-xs font-semibold text-violet-300">
            El Motor de Contenido
          </div>
          <h2 class="mb-6 text-3xl font-bold md:text-4xl">Artesanía Humana. Velocidad de IA.</h2>
          <p class="mb-8 text-zinc-400">
            La producción visual no debería ser un cuello de botella. Usamos la IA para eliminar el trabajo pesado 
            (reemplazo de fondos, localización de activos y ajustes de iluminación) para que nuestro equipo 
            creativo pueda centrarse en lo que importa: la historia y el impacto.
          </p>
          <div class="space-y-4">
            <div class="flex items-start gap-4">
              <div class="h-1 w-12 mt-3 bg-violet-400 shrink-0"></div>
              <p class="text-sm text-zinc-300"><strong class="text-zinc-100">Conceptos por IA:</strong> Previsualización rápida para alinear la dirección antes de que suene el primer obturador.</p>
            </div>
            <div class="flex items-start gap-4">
              <div class="h-1 w-12 mt-3 bg-violet-400 shrink-0"></div>
              <p class="text-sm text-zinc-300"><strong class="text-zinc-100">Escalado Inteligente:</strong> Convierta una película hero en más de 50 variantes para redes en días, no semanas.</p>
            </div>
          </div>
        </div>
        <div class="mt-12 lg:mt-0 lg:w-1/2 grid grid-cols-2 gap-4">
           <div class="aspect-[4/5] rounded-xl bg-zinc-900 border border-zinc-800 overflow-hidden relative group">
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent flex items-end p-4">
                 <p class="text-[10px] font-mono text-cyan-300">GEN_01 // PRODUCT_MESH</p>
              </div>
           </div>
           <div class="aspect-[4/5] rounded-xl bg-zinc-800 border border-zinc-700 overflow-hidden relative mt-8">
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent flex items-end p-4">
                 <p class="text-[10px] font-mono text-violet-300">POST_PRO // LIGHT_VAR</p>
              </div>
           </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Focus Areas -->
  <section class="px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16" data-animation="fade-up">
        <h2 class="mb-4 text-3xl font-bold">Capacidades de Producción</h2>
        <p class="text-zinc-400">Todo lo que necesita para construir un sistema de marca visual moderno.</p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {[
          {
            title: "Películas de Marca e Imagen",
            desc: "Películas cinematográficas de alta gama que capturan la esencia y misión de su marca.",
            icon: "🎥"
          },
          {
            title: "Fotografía de Producto",
            desc: "Imágenes técnicas y de estilo de vida diseñadas para mover productos en la web e impresos.",
            icon: "📸"
          },
          {
            title: "Contenido para Redes Sociales",
            desc: "Video vertical de formato corto y bucles de movimiento optimizados para el engagement.",
            icon: "📱"
          },
          {
            title: "Livestreams Profesionales",
            desc: "Producción de livestreams de nivel de agencia para eventos, lanzamientos de productos y paneles.",
            icon: "📡"
          }
        ].map(service => (
          <div class="flex gap-6 rounded-2xl border border-zinc-800 bg-zinc-900/20 p-8 transition-colors hover:bg-zinc-900/40" data-animation="fade-up">
            <div class="text-3xl shrink-0">{service.icon}</div>
            <div>
              <h3 class="mb-2 text-xl font-semibold">{service.title}</h3>
              <p class="text-sm text-zinc-400">{service.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="border-t border-zinc-900 px-6 py-24">
    <div class="mx-auto max-w-3xl">
      <h2 class="mb-12 text-center text-3xl font-bold md:text-4xl" data-animation="fade-up">Preguntas Frecuentes</h2>
      <div class="space-y-6" data-animation="fade-up">
        {[
          {
            q: "¿Se encargan de toda la producción o solo de la dirección?",
            a: "Hacemos ambas cosas. Podemos actuar como su líder creativo, gestionando equipos externos, o encargarnos de la producción de ciclo completo a través de nuestro equipo interno y nuestra red de socios de confianza."
          },
          {
            q: "¿Cómo utilizan la IA en su proceso de video?",
            a: "La usamos para la previsualización (para mostrarle el aspecto antes de rodar), la generación de fondos y el escalado rápido de formatos. Nunca usamos la IA como reemplazo de la fotografía de marca de alta fidelidad."
          },
          {
            q: "¿Pueden producir contenido para industrias técnicas o de nicho?",
            a: "Sí. Nuestro equipo se especializa en traducir temas complejos, desde infraestructura SaaS hasta comunicación política, en historias visuales claras."
          },
          {
            q: "¿Cuál es su tiempo de entrega típico?",
            a: "Los sprints de contenido suelen tardar de 2 a 4 semanas desde el concepto hasta los activos finales. Las películas de marca más grandes o las actualizaciones de sistemas visuales completos suelen durar de 6 a 8 semanas."
          }
        ].map(item => (
          <div class="rounded-xl border border-zinc-800 bg-zinc-900/40 p-6">
            <h3 class="mb-3 font-semibold text-zinc-200">{item.q}</h3>
            <p class="text-sm text-zinc-400 leading-relaxed">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="px-6 py-24 text-center">
    <div class="mx-auto max-w-4xl rounded-3xl bg-gradient-to-br from-cyan-400/20 to-violet-400/20 p-12 md:p-24 border border-zinc-800" data-animation="scale">
      <h2 class="mb-6 text-3xl font-bold md:text-5xl tracking-tight">¿Listo para visualizar su historia?</h2>
      <p class="mx-auto mb-10 max-w-xl text-lg text-zinc-300">
        Hable con nuestros socios senior sobre sus necesidades de contenido. Le propondremos una hoja de ruta realista, no un moodboard.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/es/contact"
          class="rounded-lg bg-cyan-400 px-8 py-4 font-semibold text-zinc-950 transition-colors hover:bg-cyan-300"
        >
          Reserve una Llamada de Proyecto
        </a>
        <a
          href="mailto:hola@ai-native.es"
          class="rounded-lg border border-zinc-700 bg-zinc-950 px-8 py-4 text-zinc-300 transition-colors hover:border-cyan-400/50"
        >
          Envíenos un Email
        </a>
      </div>
    </div>
  </section>
</Layout>
