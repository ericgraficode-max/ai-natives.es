---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';
import { ChevronRight } from '../../components/FeatherIcons.ts';
import HeroAnimation from '../../components/HeroAnimation.astro';

const services = [
  {
    title: 'Interfaz y Research',
    simple: 'Diseñamos apps y webs que la gente disfruta usando, facilitando que te compren más.',
    icon: '✨',
    link: '/es/services/user-interface-user-research'
  },
  {
    title: 'Optimización (CRO)',
    simple: 'Encontramos las "fugas" de tu web por donde pierdes clientes y las arreglamos para subir tus ingresos.',
    icon: '📈',
    link: '/es/services/conversion-optimization'
  },
  {
    title: 'Auditorías de Accesibilidad',
    simple: 'Aseguramos que tu web sea legal y usable para todos, evitándote multas y llegando a más público.',
    icon: '♿',
    link: '/es/services/european-accessibility-compliance'
  },
  {
    title: 'Fotos y Vídeo Digital',
    simple: 'Creamos visuales premium que explican tu producto mejor que cualquier texto.',
    icon: '📸',
    link: '/es/services/digital-photoshoots-video'
  },
  {
    title: 'Cumplimiento de Precios',
    simple: 'Te ayudamos con las leyes europeas de descuentos para que seas legal sin perder el gancho comercial.',
    icon: '⚖️',
    link: '/es/services/european-pricing-compliance'
  },
  {
    title: 'Marketing de Resultados',
    simple: 'Optimizamos tus campañas de Google Ads para que obtengas más ventas por cada euro invertido.',
    icon: '🎯',
    link: '/es/services/sea-performance-marketing'
  }
];

const team = [
  { name: 'Eric', role: 'Producto y Diseño', avatar: '/Eric_Martinez.jpg' },
  { name: 'Victor', role: 'CTO AI-Native', avatar: '/Victor_Arias.jpg' }
];
---

<Layout
  lang="es"
  title="Hound | ai-native | Estudio de Crecimiento Digital de Alto Rendimiento"
  description="Diseño de producto, crecimiento e ingeniería liderado por perfiles senior. Somos los cazadores de crecimiento para marcas con ambición internacional."
>
  <!-- Hero Section -->
  <header class="relative flex min-h-screen items-center justify-center overflow-hidden px-6 pt-20">
    <HeroAnimation />
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-cyan-500/50 to-transparent"></div>
    
    <div class="relative z-10 max-w-6xl mx-auto text-center">
      <div class="mb-8 inline-flex items-center gap-3 rounded-full border border-cyan-400/20 bg-zinc-950/80 px-4 py-2 text-xs font-bold uppercase tracking-widest text-cyan-400" data-animation="fade-up">
        <span class="flex h-2 w-2 rounded-full bg-cyan-500 animate-pulse"></span>
        Presentamos Hound | ai-native
      </div>
      
      <h1 class="mb-8 text-6xl font-black tracking-tighter md:text-8xl lg:text-9xl leading-[0.9]" data-animation="fade-up">
        Cazamos el <br/><span class="italic text-zinc-400">Crecimiento.</span><br/>
        <span class="bg-gradient-to-r from-cyan-300 via-sky-400 to-violet-400 bg-clip-text text-transparent">Ejecución con Precisión.</span>
      </h1>
      
      <p class="mx-auto mb-12 max-w-2xl text-xl text-zinc-400 font-medium md:text-2xl" data-animation="fade-up">
        Tu competencia tiene agencias. Tú tienes a los Hounds. Inteligencia senior de eBay, Vodafone y Flaconi, centrada en una cosa: mover tus números.
      </p>
      
      <div class="flex flex-wrap items-center justify-center gap-6" data-animation="fade-up">
        <a href="/es/contact" class="group relative inline-flex items-center gap-2 overflow-hidden rounded-2xl bg-cyan-400 px-10 py-5 font-black text-zinc-950 transition-all hover:bg-cyan-300 hover:scale-105 active:scale-95">
          Empieza la Caza
          <span class="transition-transform group-hover:translate-x-1" set:html={ChevronRight}></span>
        </a>
        <a href="javascript:void(0)" style="display:none" class="rounded-2xl border border-zinc-800 bg-zinc-900/50 px-10 py-5 font-bold text-zinc-300 transition-colors hover:border-cyan-400/50 hover:text-cyan-300">
          Nuestra Historia
        </a>
      </div>
    </div>
    
    <div class="absolute bottom-10 left-1/2 -translate-x-1/2 animate-bounce opacity-20">
      <div class="h-10 w-px bg-gradient-to-b from-cyan-400 to-transparent"></div>
    </div>
  </header>

  <!-- The Origin -->
  <section  class="relative border-y border-zinc-900 bg-zinc-950 px-6 py-32 overflow-hidden">
    <div class="absolute -right-24 top-1/4 h-96 w-96 bg-cyan-500/5 blur-[120px] rounded-full"></div>
    
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-20 lg:grid-cols-2 items-center">
        <div data-animation="fade-up">
          <p class="mb-4 text-xs font-bold uppercase tracking-[0.4em] text-cyan-500">Cómo nació todo</p>
          <h2 class="mb-8 text-5xl font-bold tracking-tight md:text-7xl leading-tight text-white">
            Dejamos a los <span class="text-zinc-600">Gigantes Corporativos</span> para construir algo más ágil.
          </h2>
          <div class="space-y-8 text-lg text-zinc-400 leading-relaxed">
            <p>
              Tras una década liderando producto e ingeniería en <span class="text-white font-bold">eBay, Vodafone y Flaconi</span>, vimos un patrón repetitivo: empresas malgastando millones en "grandes agencias" donde los socios venden el sueño, pero los juniors hacen el trabajo.
            </p>
            <p>
              Fundamos <span class="text-cyan-400 font-bold italic">Hound</span> para arreglar eso. Sin gestores de cuentas. Sin juniors aprendiendo con tu presupuesto. Solo un equipo de seniors curtidos en mil batallas que buscan la eficiencia y el crecimiento en cada línea de código y cada píxel.
            </p>
          </div>
        </div>
        
        <div class="relative" data-animation="scale">
          <div class="absolute -inset-4 rounded-[3rem] bg-gradient-to-tr from-cyan-500/20 to-violet-500/20 blur-2xl opacity-40"></div>
          <div class="relative rounded-[2.5rem] border border-zinc-800 bg-zinc-900/60 p-12 backdrop-blur-xl">
             <div class="flex gap-4 mb-8">
                {team.map(member => (
                  <div class="relative group">
                    <img src={member.avatar} alt={member.name} class="h-20 w-20 rounded-2xl grayscale group-hover:grayscale-0 transition-all duration-500 border border-zinc-700 group-hover:border-cyan-400/50" />
                    <div class="absolute -bottom-2 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-lg bg-cyan-400 px-2 py-0.5 text-[10px] font-black text-zinc-950 opacity-0 group-hover:opacity-100 transition-opacity">
                      {member.name}
                    </div>
                  </div>
                ))}
             </div>
            <p class="mb-8 text-2xl font-medium text-zinc-200 leading-tight">
              "No vendemos y luego delegamos. Auditamos, diseñamos y lanzamos. Somos Hounds porque no paramos hasta encontrar el resultado."
            </p>
            <div class="flex items-center gap-4 border-t border-zinc-800 pt-8">
              <div>
                <p class="text-sm font-black text-cyan-400 uppercase tracking-widest">El Escuadrón Core</p>
                <p class="text-xs text-zinc-500">Eric Martinez Solis & Victor</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The USP -->
  <section class="px-6 py-32 bg-zinc-950">
     <div class="mx-auto max-w-6xl">
        <div class="mb-20 text-center" data-animation="fade-up">
           <h2 class="text-4xl font-black md:text-6xl tracking-tighter mb-4">Por qué somos <span class="text-cyan-400 italic">diferentes.</span></h2>
           <p class="text-zinc-500 max-w-xl mx-auto uppercase tracking-widest text-xs font-bold">El Estándar Hound</p>
        </div>
        
        <div class="grid gap-8 md:grid-cols-3">
           <div class="group rounded-3xl border border-zinc-800 bg-zinc-900/20 p-10 hover:border-cyan-400/30 transition-all" data-animation="fade-up">
              <div class="mb-6 text-3xl">🛡️</div>
              <h3 class="text-xl font-bold mb-4 text-white">Solo Perfiles Senior</h3>
              <p class="text-zinc-400 text-sm leading-relaxed">Hablas con quienes construyen. Sin intermediarios ni teléfonos escacharrados. Acceso directo a talento de élite.</p>
           </div>
           <div class="group rounded-3xl border border-zinc-800 bg-zinc-900/20 p-10 hover:border-violet-400/30 transition-all" data-animation="fade-up">
              <div class="mb-6 text-3xl">⚡</div>
              <h3 class="text-xl font-bold mb-4 text-white">Velocidad AI-Native</h3>
              <p class="text-zinc-400 text-sm leading-relaxed">Usamos IA para automatizar lo aburrido, permitiéndonos lanzar en semanas lo que a otros les lleva meses.</p>
           </div>
           <div class="group rounded-3xl border border-zinc-800 bg-zinc-900/20 p-10 hover:border-cyan-400/30 transition-all" data-animation="fade-up">
              <div class="mb-6 text-3xl">🌎</div>
              <h3 class="text-xl font-bold mb-4 text-white">Estándares Intl.</h3>
              <p class="text-zinc-400 text-sm leading-relaxed">Desde España y Berlín, traemos el rigor de plataformas europeas de más de 100M€ a cada proyecto.</p>
           </div>
        </div>
     </div>
  </section>

  <!-- Services -->
  <section id="services" class="px-6 py-32 border-t border-zinc-900">
    <div class="mx-auto max-w-6xl">
      <div class="mb-24" data-animation="fade-up">
        <h2 class="mb-4 text-5xl font-black md:text-7xl tracking-tighter">Palancas de <span class="text-zinc-600 italic">Crecimiento.</span></h2>
        <p class="max-w-2xl text-lg text-zinc-400">Intervenciones específicas de alto impacto diseñadas para resolver cuellos de botella y acelerar tu motor digital.</p>
      </div>

      <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
        {services.map(service => (
          <a href={service.link} class="group relative overflow-hidden rounded-[2rem] border border-zinc-800 bg-zinc-900/20 p-10 transition-all hover:border-cyan-400/40 hover:bg-zinc-900/40" data-animation="fade-up">
            <div class="mb-8 inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-zinc-800 text-4xl transition-transform group-hover:scale-110 group-hover:rotate-6">
              {service.icon}
            </div>
            <h3 class="mb-4 text-2xl font-black group-hover:text-cyan-300 transition-colors tracking-tight">{service.title}</h3>
            <p class="mb-10 text-zinc-500 leading-relaxed font-medium">{service.simple}</p>
            <div class="flex items-center gap-2 text-xs font-black uppercase tracking-widest text-cyan-400 opacity-0 transition-all group-hover:opacity-100 group-hover:translate-x-2">
              Explorar Palanca <span class="h-4 w-4" set:html={ChevronRight}></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="px-6 py-32">
    <div class="mx-auto max-w-5xl rounded-[3rem] bg-gradient-to-br from-cyan-400/10 via-zinc-950 to-zinc-950 p-12 text-center md:p-24 border border-zinc-800/50 relative overflow-hidden" data-animation="scale">
      <div class="absolute -top-24 -left-24 h-96 w-96 bg-cyan-500/10 blur-[120px] rounded-full"></div>
      
      <div class="relative z-10">
         <h2 class="mb-8 text-5xl font-black md:text-8xl tracking-tighter leading-none">¿Listo para <br/><span class="text-cyan-400 italic">mover la aguja?</span></h2>
         <p class="mx-auto mb-12 max-w-xl text-xl text-zinc-400 font-medium">
           No te conformes con "suficiente". Contrata a los seniors que realmente harán el trabajo. La caza empieza aquí.
         </p>
         <div class="flex flex-wrap justify-center gap-6">
           <a href="/es/contact" class="rounded-2xl bg-cyan-400 px-12 py-6 font-black text-zinc-950 transition-all hover:bg-cyan-300 hover:scale-105 active:scale-95">
             Reserva una Sesión Estratégica
           </a>
           <a href="mailto:hola@ai-native.es" class="rounded-2xl border border-zinc-700 bg-zinc-950 px-12 py-6 font-bold text-zinc-300 transition-colors hover:border-cyan-400/50">
             Email Directo
           </a>
         </div>
      </div>
    </div>
  </section>

</Layout>
