---
import Layout from '../../layouts/Layout.astro';
import ContactForm from '../../components/ContactForm.astro';
import { ChevronRight } from '../../components/FeatherIcons.ts';

const services = [
  {
    title: 'Interfaz y Research',
    simple: 'Diseñamos apps y webs que la gente disfruta usando, facilitando que te compren más.',
    icon: '✨',
    link: '/es/services/user-interface-user-research'
  },
  {
    title: 'Optimización (CRO)',
    simple: 'Encontramos las "fugas" de tu web por donde pierdes clientes y las arreglamos para subir tus ingresos.',
    icon: '📈',
    link: '/es/services/conversion-optimization'
  },
  {
    title: 'Auditorías de Accesibilidad',
    simple: 'Aseguramos que tu web sea legal y usable para todos, evitándote multas y llegando a más público.',
    icon: '♿',
    link: '/es/services/european-accessibility-compliance'
  },
  {
    title: 'Fotos y Vídeo Digital',
    simple: 'Creamos visuales premium que explican tu producto mejor que cualquier texto.',
    icon: '📸',
    link: '/es/services/digital-photoshoots-video'
  },
  {
    title: 'Cumplimiento de Precios',
    simple: 'Te ayudamos con las leyes europeas de descuentos para que seas legal sin perder el gancho comercial.',
    icon: '⚖️',
    link: '/es/services/european-pricing-compliance'
  },
  {
    title: 'Marketing de Resultados',
    simple: 'Optimizamos tus campañas de Google Ads para que obtengas más ventas por cada euro invertido.',
    icon: '🎯',
    link: '/es/services/sea-performance-marketing'
  }
];
---

<Layout
  lang="es"
  title="AI‑Native.es | Estudio de Crecimiento Digital de Alto Rendimiento"
  description="Diseño de producto, crecimiento e ingeniería liderado por perfiles senior. Creamos experiencias que mueven los números."
>
  <!-- Hero Section -->
  <header class="relative flex min-h-[90vh] items-center justify-center overflow-hidden px-6 pt-20">
    <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,rgba(16,185,129,0.05),transparent)] opacity-50"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-cyan-500/50 to-transparent"></div>
    
    <div class="relative z-10 max-w-5xl mx-auto text-center">
      <div class="mb-8 inline-flex items-center gap-2 rounded-full border border-cyan-400/20 bg-cyan-400/10 px-4 py-1.5 text-xs font-semibold text-cyan-300" data-animation="fade-up">
        <span class="relative flex h-2 w-2">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-cyan-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-cyan-500"></span>
        </span>
        Solo perfiles senior. Resultados reales. Sin humo.
      </div>
      
      <h1 class="mb-6 text-5xl font-bold tracking-tight md:text-7xl lg:text-8xl" data-animation="fade-up">
        Creamos productos digitales que <span class="bg-gradient-to-r from-cyan-300 via-sky-400 to-violet-400 bg-clip-text text-transparent">mueven la aguja.</span>
      </h1>
      
      <p class="mx-auto mb-10 max-w-2xl text-lg text-zinc-300 md:text-xl" data-animation="fade-up">
        Deja de adivinar. Traemos experiencia internacional de eBay, Vodafone y Flaconi para ayudar a marcas españolas a escalar con precisión y calidad senior.
      </p>
      
      <div class="flex flex-wrap items-center justify-center gap-4" data-animation="fade-up">
        <a href="/es/contact" class="rounded-xl bg-cyan-400 px-8 py-4 font-bold text-zinc-950 transition-all hover:bg-cyan-300 hover:scale-105 active:scale-95">
          Empieza un proyecto
        </a>
        <a href="#services" class="rounded-xl border border-zinc-800 bg-zinc-900/50 px-8 py-4 font-semibold text-zinc-300 transition-colors hover:border-cyan-400/50 hover:text-cyan-300">
          Cómo te ayudamos
        </a>
      </div>
    </div>
  </header>

  <!-- Section "Por qué nosotros" -->
  <section class="border-y border-zinc-900 bg-zinc-950/50 px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-16 lg:grid-cols-2 items-center">
        <div data-animation="fade-up">
          <h2 class="mb-8 text-4xl font-bold leading-tight md:text-5xl">Tienes un problema de crecimiento. <br/><span class="text-zinc-500">Nosotros tenemos la solución senior.</span></h2>
          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-red-500/10 text-red-500">✕</div>
              <div>
                <h4 class="font-semibold text-zinc-200">La trampa de las agencias</h4>
                <p class="text-sm text-zinc-400">Equipos junior aprendiendo con tu presupuesto, procesos lentos y diseños genéricos.</p>
              </div>
            </div>
            <div class="flex gap-4">
              <div class="flex h-10 w-10 shrink-0 items-center justify-center rounded-lg bg-green-500/10 text-green-500">✓</div>
              <div>
                <h4 class="font-semibold text-zinc-200">El enfoque AI-Native</h4>
                <p class="text-sm text-zinc-400">Dos socios senior en cada llamada. Trabajo de alta fidelidad lanzado en semanas, no meses. Lógica basada en datos.</p>
              </div>
            </div>
          </div>
        </div>
        <div class="relative" data-animation="scale">
          <div class="absolute -inset-4 rounded-3xl bg-gradient-to-tr from-cyan-500/20 to-violet-500/20 blur-2xl opacity-30"></div>
          <div class="relative rounded-2xl border border-zinc-800 bg-zinc-900/40 p-8">
            <p class="mb-6 text-xl font-medium italic text-zinc-300 leading-relaxed">
              "Trabajar con Eric y Victor fue como contratar a un equipo de producto dedicado de la noche a la mañana. No solo 'diseñan'; resuelven problemas de negocio con código y datos."
            </p>
            <div class="flex items-center gap-4">
              <div class="h-12 w-12 rounded-full bg-zinc-800 border border-zinc-700"></div>
              <div>
                <p class="text-sm font-bold">Responsable de Producto</p>
                <p class="text-xs text-zinc-500">Retailer líder europeo</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Cuadrícula de Servicios -->
  <section id="services" class="px-6 py-32">
    <div class="mx-auto max-w-6xl">
      <div class="mb-20 text-center" data-animation="fade-up">
        <h2 class="mb-4 text-4xl font-bold md:text-6xl tracking-tight">Cómo movemos tus números</h2>
        <p class="mx-auto max-w-2xl text-zinc-400">Sin jerga técnica. Solo servicios de alto impacto diseñados para resolver cuellos de botella específicos en tu negocio digital.</p>
      </div>

      <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
        {services.map(service => (
          <a href={service.link} class="group relative rounded-3xl border border-zinc-800 bg-zinc-900/30 p-8 transition-all hover:border-cyan-400/40 hover:bg-zinc-900/50" data-animation="fade-up">
            <div class="mb-6 inline-flex h-14 w-14 items-center justify-center rounded-2xl bg-zinc-800 text-3xl transition-transform group-hover:scale-110 group-hover:rotate-3">
              {service.icon}
            </div>
            <h3 class="mb-3 text-2xl font-bold group-hover:text-cyan-300 transition-colors">{service.title}</h3>
            <p class="mb-8 text-zinc-400 leading-relaxed">{service.simple}</p>
            <div class="flex items-center gap-2 text-sm font-bold text-cyan-400 opacity-0 transition-all group-hover:opacity-100 group-hover:translate-x-2">
              Saber más <span set:html={ChevronRight}></span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="px-6 py-24">
    <div class="mx-auto max-w-4xl rounded-[2.5rem] bg-gradient-to-br from-cyan-400/20 via-violet-400/10 to-transparent p-12 text-center md:p-24 border border-zinc-800/50 overflow-hidden relative" data-animation="scale">
      <div class="absolute -top-24 -left-24 h-64 w-64 bg-cyan-500/10 blur-[100px] rounded-full"></div>
      <div class="absolute -bottom-24 -right-24 h-64 w-64 bg-violet-500/10 blur-[100px] rounded-full"></div>
      
      <h2 class="relative z-10 mb-6 text-4xl font-bold md:text-6xl tracking-tight">¿Listo para construir algo serio?</h2>
      <p class="relative z-10 mx-auto mb-10 max-w-xl text-lg text-zinc-300">
        Sin rodeos. Habla directamente con los socios que harán el trabajo. Sin gestores de cuentas, solo resultados.
      </p>
      <div class="relative z-10 flex flex-wrap justify-center gap-4">
        <a href="/es/contact" class="rounded-xl bg-cyan-400 px-10 py-5 font-bold text-zinc-950 transition-all hover:bg-cyan-300 hover:scale-105 active:scale-95">
          Reserva una llamada
        </a>
        <a href="mailto:hola@ai-native.es" class="rounded-xl border border-zinc-700 bg-zinc-950 px-10 py-5 font-semibold text-zinc-300 transition-colors hover:border-cyan-400/50">
          Escríbenos directamente
        </a>
      </div>
    </div>
  </section>

</Layout>
