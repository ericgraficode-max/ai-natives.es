---
import Layout from '../../layouts/Layout.astro';
import { ChevronRight } from '../../components/FeatherIcons.ts';
---

<Layout
  title="User Interface & User Research | Hound | ai-native"
  description="Senior-led product design and research for European platforms. We bridge the gap between user insights and high-fidelity, implementation-ready interfaces."
>
  <!-- Hero Section -->
  <section class="service-hero-section relative overflow-hidden px-6 pb-32 pt-24 md:pt-32">
    <div class="absolute inset-0 -z-20 mask-gradient-to-right">
      <img src="/1_conversion_optimization_.webp" alt="" class="h-full w-full object-cover" />
    </div>
    <div class="absolute inset-0 -z-10 opacity-20">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-cyan-500/20 rounded-full blur-3xl animate-pulse" />
      <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-violet-500/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s" />
    </div>

    <div class="mx-auto max-w-5xl text-center" data-animation="fade-up">
      <p class="mb-4 text-xs font-semibold uppercase tracking-[0.3em] text-cyan-300">
        Evidence-Based Design
      </p>
      <h1 class="mb-6 text-4xl font-bold tracking-tight md:text-6xl lg:text-7xl">
        Ship products that <span class="bg-gradient-to-r from-cyan-300 to-violet-400 bg-clip-text text-transparent">feel obvious.</span>
      </h1>
      <p class="mx-auto mb-10 max-w-3xl text-lg text-zinc-400 md:text-xl">
        Most design is based on internal opinions. We build products the way we've worked inside Europe's 
        top platforms: close to the user, close to the data, and focused on moving the numbers.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/contact"
          class="rounded-lg bg-cyan-400 px-8 py-4 font-semibold text-zinc-950 transition-colors hover:bg-cyan-300"
        >
          Book a Discovery Call
        </a>
        <a
          href="#methodology"
          class="rounded-lg border border-zinc-700 px-8 py-4 text-zinc-300 transition-colors hover:border-cyan-400/50 hover:text-cyan-300"
        >
          Explore Our Process
        </a>
      </div>
    </div>
  </section>

  <!-- Value Proposition -->
  <section class="border-y border-zinc-900 bg-zinc-950/50 px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-12 lg:grid-cols-2 items-center">
        <div data-animation="fade-up">
          <h2 class="mb-6 text-3xl font-bold md:text-4xl">Design is a growth lever, not a coat of paint</h2>
          <p class="mb-6 text-zinc-400">
            We've led design and research for platforms reaching millions of users. We bring that 
            international standard to Spanish product teams, cutting through the fluff to deliver 
            interfaces that are as functional as they are beautiful.
          </p>
          <ul class="space-y-4">
            {[
              "Discovery sprints to define the right problem",
              "Lean research that fits into 2-week build cycles",
              "Design systems that scale with your engineering team",
              "High-fidelity UI focused on clarity and conversion"
            ].map(item => (
              <li class="flex items-center gap-3 text-zinc-300">
                <span class="flex h-5 w-5 items-center justify-center rounded-full bg-cyan-400/20 text-cyan-400 text-xs">✓</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="relative rounded-2xl border border-zinc-800 bg-zinc-900/40 p-8 lg:p-12" data-animation="scale">
           <div class="space-y-6">
              <div class="flex gap-4">
                 <div class="h-12 w-12 rounded-lg bg-zinc-800 border border-zinc-700 flex items-center justify-center text-xl">💡</div>
                 <div class="flex-1">
                    <p class="text-xs font-bold text-cyan-300 uppercase tracking-widest mb-1">Insight</p>
                    <p class="text-sm text-zinc-300">"Users are dropping off at step 3 because they don't understand the pricing tiers."</p>
                 </div>
              </div>
              <div class="flex gap-4">
                 <div class="h-12 w-12 rounded-lg bg-zinc-800 border border-zinc-700 flex items-center justify-center text-xl">📐</div>
                 <div class="flex-1">
                    <p class="text-xs font-bold text-violet-300 uppercase tracking-widest mb-1">Solution</p>
                    <p class="text-sm text-zinc-300">Simplified comparison matrix with clear value-mapping for each segment.</p>
                 </div>
              </div>
              <div class="pt-4 border-t border-zinc-800 flex justify-between items-center">
                 <span class="text-[10px] text-zinc-500 font-mono">ITERATION_03</span>
                 <span class="text-[10px] text-zinc-500 font-mono text-green-400">VALIDATED</span>
              </div>
           </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Methodology Section -->
  <section id="methodology" class="px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16 text-center" data-animation="fade-up">
        <h2 class="mb-4 text-3xl font-bold md:text-5xl">The Insight-to-Interface Loop</h2>
        <p class="mx-auto max-w-2xl text-zinc-400">
          We move fast without skipping steps. Our framework ensures every pixel is backed 
          by user evidence and business logic.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
        {[
          {
            step: "01",
            title: "Discovery",
            desc: "Mapping the problem space, user journeys, and technical constraints.",
            icon: "🔭"
          },
          {
            step: "02",
            title: "Research",
            desc: "Validating assumptions through lean user testing and data analysis.",
            icon: "🧪"
          },
          {
            step: "03",
            title: "Design",
            desc: "Building high-fidelity UI and interactive prototypes in Figma.",
            icon: "✏️"
          },
          {
            step: "04",
            title: "Validate",
            desc: "Usability testing and handover to engineering for pixel-perfect build.",
            icon: "✅"
          }
        ].map(item => (
          <div class="group relative rounded-2xl border border-zinc-800 bg-zinc-900/30 p-8 transition-colors hover:border-cyan-400/40" data-animation="fade-up">
            <span class="absolute top-4 right-6 text-4xl font-black text-zinc-800/50 transition-colors group-hover:text-cyan-400/10">{item.step}</span>
            <div class="mb-6 text-3xl">{item.icon}</div>
            <h3 class="mb-3 text-xl font-semibold">{item.title}</h3>
            <p class="text-sm text-zinc-400 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Creative Middle Section: Design Systems -->
  <section class="bg-gradient-to-b from-zinc-950 to-zinc-900 px-6 py-24 overflow-hidden">
    <div class="mx-auto max-w-6xl">
      <div class="rounded-3xl border border-cyan-400/20 bg-cyan-950/5 p-8 md:p-16 lg:flex items-center gap-16" data-animation="fade-up">
        <div class="lg:w-1/2">
          <div class="mb-6 inline-flex rounded-full bg-cyan-400/10 px-4 py-1 text-xs font-semibold text-cyan-300">
            Systems Thinking
          </div>
          <h2 class="mb-6 text-3xl font-bold md:text-4xl">Design systems that actually get used.</h2>
          <p class="mb-8 text-zinc-400">
            We don't build "art projects." We build living component libraries that align with 
            your frontend architecture (React, Vue, Astro). Our goal is to empower your team 
            to ship consistent UI faster, long after our engagement ends.
          </p>
          <div class="space-y-4">
             <div class="flex items-start gap-4">
                <div class="h-1 w-12 mt-3 bg-cyan-400 shrink-0"></div>
                <p class="text-sm text-zinc-300"><strong class="text-zinc-100">Component-First:</strong> Every element is a reusable, documented asset.</p>
             </div>
             <div class="flex items-start gap-4">
                <div class="h-1 w-12 mt-3 bg-cyan-400 shrink-0"></div>
                <p class="text-sm text-zinc-300"><strong class="text-zinc-100">Dev-Ready Handover:</strong> Pixel-perfect specs with clear tokens and logic.</p>
             </div>
          </div>
        </div>
        <div class="mt-12 lg:mt-0 lg:w-1/2 relative">
           <div class="grid grid-cols-3 gap-3">
              {Array.from({length: 9}).map((_, i) => (
                <div class={`aspect-square rounded-xl border border-zinc-800 bg-zinc-900/40 p-4 flex flex-col justify-between ${i === 4 ? 'border-cyan-400/50 bg-cyan-400/10' : ''}`}>
                   <div class={`h-2 w-full rounded-full ${i % 3 === 0 ? 'bg-cyan-400' : 'bg-zinc-800'}`}></div>
                   <div class="space-y-1">
                      <div class="h-1 w-2/3 bg-zinc-800 rounded-full"></div>
                      <div class="h-1 w-1/2 bg-zinc-800 rounded-full"></div>
                   </div>
                </div>
              ))}
           </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Focus Areas -->
  <section class="px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16" data-animation="fade-up">
        <h2 class="mb-4 text-3xl font-bold">Design & Research Capabilities</h2>
        <p class="text-zinc-400">End-to-end product design services from insight to launch.</p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {[
          {
            title: "Product Discovery Sprints",
            desc: "Intensive workshops to align stakeholders and define the MVP for new products or features.",
            icon: "🚀"
          },
          {
            title: "Lean User Research",
            desc: "Rapid testing and interviews to validate UX decisions before they hit production.",
            icon: "🔬"
          },
          {
            title: "Scalable Design Systems",
            desc: "Figma libraries that mirror your code, ensuring consistency and speed across teams.",
            icon: "🧱"
          },
          {
            title: "High-Fidelity Prototyping",
            desc: "Interactive, implementation-ready prototypes that feel like the real thing.",
            icon: "📱"
          }
        ].map(service => (
          <div class="flex gap-6 rounded-2xl border border-zinc-800 bg-zinc-900/20 p-8 transition-colors hover:bg-zinc-900/40" data-animation="fade-up">
            <div class="text-3xl shrink-0">{service.icon}</div>
            <div>
              <h3 class="mb-2 text-xl font-semibold">{service.title}</h3>
              <p class="text-sm text-zinc-400">{service.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="border-t border-zinc-900 px-6 py-24">
    <div class="mx-auto max-w-3xl">
      <h2 class="mb-12 text-center text-3xl font-bold md:text-4xl" data-animation="fade-up">Design & Research FAQ</h2>
      <div class="space-y-6" data-animation="fade-up">
        {[
          {
            q: "How do you integrate with our engineering team?",
            a: "We speak their language. We provide implementation-ready Figma files, clear component logic, and are comfortable joining standups to ensure the design vision is technically feasible."
          },
          {
            q: "Can you help us build a design system from scratch?",
            a: "Yes. We've built systems for platforms with hundreds of designers and engineers. We'll help you set the foundation and train your team on how to maintain it."
          },
          {
            q: "How long does a typical discovery sprint take?",
            a: "A standard discovery sprint runs for 1-2 weeks, depending on the complexity of the problem space and the number of stakeholders involved."
          },
          {
            q: "Do you only work in Figma?",
            a: "Figma is our primary tool for design and collaboration, but we also utilize various research tools and are comfortable working within your existing tech stack for handovers."
          }
        ].map(item => (
          <div class="rounded-xl border border-zinc-800 bg-zinc-900/40 p-6">
            <h3 class="mb-3 font-semibold text-zinc-200">{item.q}</h3>
            <p class="text-sm text-zinc-400 leading-relaxed">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="px-6 py-24 text-center">
    <div class="mx-auto max-w-4xl rounded-3xl bg-gradient-to-br from-cyan-400/20 to-violet-400/20 p-12 md:p-24 border border-zinc-800" data-animation="scale">
      <h2 class="mb-6 text-3xl font-bold md:text-5xl tracking-tight">Ready to build something people love?</h2>
      <p class="mx-auto mb-10 max-w-xl text-lg text-zinc-300">
        Talk to our design partners about your product roadmap. No account managers, just senior leads on every call.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/contact"
          class="rounded-lg bg-cyan-400 px-8 py-4 font-semibold text-zinc-950 transition-colors hover:bg-cyan-300"
        >
          Book a Project Call
        </a>
        <a
          href="mailto:hola@ai-native.es"
          class="rounded-lg border border-zinc-700 bg-zinc-950 px-8 py-4 text-zinc-300 transition-colors hover:border-cyan-400/50"
        >
          Email Us Directly
        </a>
      </div>
    </div>
  </section>
</Layout>
