---
import Layout from '../../layouts/Layout.astro';
import { ChevronRight } from '../../components/FeatherIcons.ts';
---

<Layout
  title="Conversion Optimization & Experimentation (CRO) | Hound | ai-native"
  description="Senior-led CRO programs that turn your existing traffic into sustainable revenue. No fluff, just data-driven experimentation that moves the numbers."
>
  <!-- Hero Section -->
  <section class="service-hero-section relative overflow-hidden px-6 pb-32 pt-24 md:pt-32">
    <div class="absolute inset-0 -z-20 mask-gradient-to-right">
      <img src="/1_conversion_optimization_.webp" alt="" class="h-full w-full object-cover" />
    </div>
    <div class="absolute inset-0 -z-10 opacity-20">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-cyan-500/20 rounded-full blur-3xl animate-pulse" />
      <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-violet-500/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s" />
    </div>

    <div class="mx-auto max-w-5xl text-center" data-animation="fade-up">
      <p class="mb-4 text-xs font-semibold uppercase tracking-[0.3em] text-cyan-300">
        High-Performance Growth
      </p>
      <h1 class="mb-6 text-4xl font-bold tracking-tight md:text-6xl lg:text-7xl">
        Stop burning budget on more traffic. <span class="bg-gradient-to-r from-cyan-300 to-violet-400 bg-clip-text text-transparent">Start converting it.</span>
      </h1>
      <p class="mx-auto mb-10 max-w-3xl text-lg text-zinc-400 md:text-xl">
        Most brands have a traffic problem. They buy more ads instead of fixing the leaky bucket. 
        We run senior-led CRO programs that turn your existing visitors into loyal customers.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/contact"
          class="rounded-lg bg-cyan-400 px-8 py-4 font-semibold text-zinc-950 transition-colors hover:bg-cyan-300"
        >
          Book a CRO Strategy Call
        </a>
        <a
          href="#methodology"
          class="rounded-lg border border-zinc-700 px-8 py-4 text-zinc-300 transition-colors hover:border-cyan-400/50 hover:text-cyan-300"
        >
          Explore Our Process
        </a>
      </div>
    </div>
  </section>

  <!-- Value Proposition: The EBITDA Lever -->
  <section class="border-y border-zinc-900 bg-zinc-950/50 px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-12 lg:grid-cols-2 items-center">
        <div data-animation="fade-up">
          <h2 class="mb-6 text-3xl font-bold md:text-4xl">Why CRO is your most powerful growth lever</h2>
          <p class="mb-6 text-zinc-400">
            Ad costs are rising 20% year-on-year. Relying solely on acquisition is a race to the bottom. 
            Conversion Optimization (CRO) is the only marketing activity that improves the efficiency of 
            <em>every</em> euro you spend.
          </p>
          <ul class="space-y-4">
            {[
              "Lower Customer Acquisition Costs (CAC)",
              "Increased Average Order Value (AOV)",
              "Higher Customer Lifetime Value (LTV)",
              "Direct impact on EBITDA and margin"
            ].map(item => (
              <li class="flex items-center gap-3 text-zinc-300">
                <span class="flex h-5 w-5 items-center justify-center rounded-full bg-cyan-400/20 text-cyan-400 text-xs">✓</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="relative rounded-2xl border border-zinc-800 bg-zinc-900/40 p-8 lg:p-12" data-animation="scale">
          <div class="absolute -top-4 -right-4 h-24 w-24 rounded-full bg-violet-500/10 blur-2xl" />
          <div class="space-y-6">
            <div class="flex justify-between items-end border-b border-zinc-800 pb-4">
              <div>
                <p class="text-xs text-zinc-500 uppercase tracking-widest">Typical Result</p>
                <p class="text-2xl font-bold text-cyan-300">+24% Revenue</p>
              </div>
              <div class="text-right">
                <p class="text-xs text-zinc-500">Ad Spend</p>
                <p class="text-sm font-semibold text-zinc-300">Constant</p>
              </div>
            </div>
            <p class="text-sm italic text-zinc-400">
              "Working with the AI‑Native team, we didn't just see a lift in CR, we understood *why* our users were hesitating for the first time."
            </p>
            <div class="flex items-center gap-3">
              <div class="h-10 w-10 rounded-full bg-zinc-800" />
              <div>
                <p class="text-xs font-bold">Growth Lead</p>
                <p class="text-[10px] text-zinc-500">Tier 1 E-commerce Player</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Methodology Section -->
  <section id="methodology" class="px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16 text-center" data-animation="fade-up">
        <h2 class="mb-4 text-3xl font-bold md:text-5xl">Our Full-Cycle CRO Strategy</h2>
        <p class="mx-auto max-w-2xl text-zinc-400">
          We don't do "quick hacks". We follow a rigorous, scientific process used by top-tier agencies like LEAP, 
          enhanced with AI-native speed and precision.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
        {[
          {
            step: "01",
            title: "Analysis",
            desc: "Quantitative data (GA4, heatmaps) meets qualitative insights (user testing, surveys) to find the 'Why'.",
            icon: "📊"
          },
          {
            step: "02",
            title: "Strategy",
            desc: "We prioritize tests based on potential impact, confidence, and ease of implementation (PIE Framework).",
            icon: "🎯"
          },
          {
            step: "03",
            title: "Execution",
            desc: "High-fidelity design and rapid prototyping of experiments. We handle the technical setup.",
            icon: "⚡"
          },
          {
            step: "04",
            title: "Success",
            desc: "Statistical analysis of results. We scale the winners and learn from the losers to iterate.",
            icon: "📈"
          }
        ].map(item => (
          <div class="group relative rounded-2xl border border-zinc-800 bg-zinc-900/30 p-8 transition-colors hover:border-cyan-400/40" data-animation="fade-up">
            <span class="absolute top-4 right-6 text-4xl font-black text-zinc-800/50 transition-colors group-hover:text-cyan-400/10">{item.step}</span>
            <div class="mb-6 text-3xl">{item.icon}</div>
            <h3 class="mb-3 text-xl font-semibold">{item.title}</h3>
            <p class="text-sm text-zinc-400 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- AI-Native Advantage -->
  <section class="bg-gradient-to-b from-zinc-950 to-zinc-900 px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="rounded-3xl border border-cyan-400/20 bg-cyan-950/5 p-8 md:p-16 lg:flex items-center gap-16" data-animation="fade-up">
        <div class="lg:w-1/2">
          <div class="mb-6 inline-flex rounded-full bg-cyan-400/10 px-4 py-1 text-xs font-semibold text-cyan-300">
            The AI-Native Advantage
          </div>
          <h2 class="mb-6 text-3xl font-bold md:text-4xl">Smarter data, faster cycles.</h2>
          <p class="mb-8 text-zinc-400">
            We use AI not as a buzzword, but as a tool to accelerate the CRO loop. From automated behavioral 
            pattern recognition to AI-assisted predictive heatmaps, we get to the winning hypothesis faster.
          </p>
          <div class="grid gap-6 sm:grid-cols-2">
            <div>
              <h4 class="mb-2 font-semibold text-zinc-200">Behavioral Prediction</h4>
              <p class="text-xs text-zinc-400">Predicting drop-off points before they happen at scale.</p>
            </div>
            <div>
              <h4 class="mb-2 font-semibold text-zinc-200">Automated Insights</h4>
              <p class="text-xs text-zinc-400">Synthesizing thousands of user session recordings in minutes.</p>
            </div>
          </div>
        </div>
        <div class="mt-12 lg:mt-0 lg:w-1/2 relative">
          <div class="aspect-square rounded-2xl bg-zinc-900 border border-zinc-800 overflow-hidden flex items-center justify-center p-8">
             <!-- Placeholder for interactive graphic -->
             <div class="grid grid-cols-6 grid-rows-6 gap-2 w-full h-full opacity-40">
                {Array.from({length: 36}).map((_, i) => (
                  <div class={`rounded-sm ${i % 7 === 0 ? 'bg-cyan-400' : i % 3 === 0 ? 'bg-violet-400' : 'bg-zinc-800'}`} style={`opacity: ${Math.random() * 0.5 + 0.2}`}></div>
                ))}
             </div>
             <div class="absolute inset-0 flex items-center justify-center">
                <div class="rounded-lg bg-zinc-950/80 p-6 border border-zinc-700 backdrop-blur-sm">
                  <p class="text-xs font-mono text-cyan-300">ANALYZING PATTERNS...</p>
                  <div class="mt-2 h-1 w-48 bg-zinc-800 rounded-full overflow-hidden">
                    <div class="h-full bg-cyan-400 animate-[loading_2s_infinite]" style="width: 60%"></div>
                  </div>
                </div>
             </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Focus Areas -->
  <section class="px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16" data-animation="fade-up">
        <h2 class="mb-4 text-3xl font-bold">Specialized Optimization</h2>
        <p class="text-zinc-400">Comprehensive services tailored to your specific conversion bottlenecks.</p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {[
          {
            title: "A/B & Multivariate Testing",
            desc: "Scientific validation of every change. We handle the split testing from setup to statistical significance.",
            icon: "🧪"
          },
          {
            title: "User Research & UX Audit",
            desc: "Finding the psychological friction points in your funnel through lab-style user testing and surveys.",
            icon: "🔍"
          },
          {
            title: "Checkout & Cart Optimization",
            desc: "Removing the last-mile barriers that cause high-intent users to abandon their purchase.",
            icon: "🛒"
          },
          {
            title: "Landing Page Personalization",
            desc: "Tailoring the experience to different traffic sources and user segments for maximum relevance.",
            icon: "👤"
          }
        ].map(service => (
          <div class="flex gap-6 rounded-2xl border border-zinc-800 bg-zinc-900/20 p-8 transition-colors hover:bg-zinc-900/40" data-animation="fade-up">
            <div class="text-3xl shrink-0">{service.icon}</div>
            <div>
              <h3 class="mb-2 text-xl font-semibold">{service.title}</h3>
              <p class="text-sm text-zinc-400">{service.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- The CRO Audit: Entry Point -->
  <section class="border-y border-zinc-900 bg-zinc-900/10 px-6 py-24">
    <div class="mx-auto max-w-4xl">
      <div class="text-center mb-16" data-animation="fade-up">
        <h2 class="mb-4 text-3xl font-bold md:text-4xl">Not ready for a full program?</h2>
        <p class="text-zinc-400">Start with a comprehensive CRO Audit. We'll identify your top 10 conversion killers in 14 days.</p>
      </div>
      
      <div class="grid gap-8 md:grid-cols-3" data-animation="fade-up">
        {[
          { title: "Heuristic Evaluation", desc: "Expert walkthrough identifying UX friction points." },
          { title: "Data Deep-Dive", desc: "GA4 and heatmap analysis to find where users drop off." },
          { title: "Actionable Roadmap", desc: "A prioritized list of fixes and test hypotheses." }
        ].map(item => (
          <div class="text-center">
            <div class="mb-4 inline-flex h-12 w-12 items-center justify-center rounded-full bg-cyan-400/10 text-cyan-400">
              <span set:html={ChevronRight}></span>
            </div>
            <h4 class="mb-2 font-semibold">{item.title}</h4>
            <p class="text-xs text-zinc-500">{item.desc}</p>
          </div>
        ))}
      </div>
      
      <div class="mt-12 text-center" data-animation="fade-up">
        <a href="/contact" class="inline-flex items-center gap-2 text-sm font-semibold text-cyan-300 hover:text-cyan-200 transition-colors">
          Learn more about our CRO Audit <span set:html={ChevronRight}></span>
        </a>
      </div>
    </div>
  </section>

  <!-- Technology Stack -->
  <section class="px-6 py-24">
    <div class="mx-auto max-w-6xl text-center">
      <h2 class="mb-12 text-2xl font-bold text-zinc-400 uppercase tracking-widest" data-animation="fade-up">We work with your stack</h2>
      <div class="flex flex-wrap justify-center gap-8 md:gap-16 opacity-50 grayscale hover:grayscale-0 transition-all" data-animation="fade-up">
        {["Optimizely", "VWO", "AB Tasty", "Google Analytics 4", "Hotjar", "PostHog", "Shopify", "Contentful"].map(tool => (
          <span class="text-lg font-bold text-zinc-500 tracking-tighter">{tool}</span>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="border-t border-zinc-900 px-6 py-24">
    <div class="mx-auto max-w-3xl">
      <h2 class="mb-12 text-center text-3xl font-bold md:text-4xl" data-animation="fade-up">Frequently Asked Questions</h2>
      <div class="space-y-6" data-animation="fade-up">
        {[
          {
            q: "How much traffic do I need for a CRO program?",
            a: "For meaningful A/B tests, we typically look for at least 500-1,000 conversions per month per funnel. If you have less, we focus on 'heuristic analysis' and high-impact UX improvements where the signal is clear."
          },
          {
            q: "How long before we see results?",
            a: "We usually find 'low-hanging fruit' within the first 30 days during the initial audit. A full experimentation program typically sees its first major winners within 60-90 days."
          },
          {
            q: "Do I need to change my tech stack?",
            a: "No. We work with standard tools like Optimizely, VWO, or even custom scripts. We integrate with your existing analytics (GA4, PostHog, etc.) and development workflow."
          },
          {
            q: "Why hire an agency instead of an in-house person?",
            a: "You get access to a senior squad (Lead Strategist, UX Designer, and Engineer) for less than the cost of one senior hire. Plus, we bring cross-industry insights from brands like flaconi, eBay, and Vodafone."
          }
        ].map(item => (
          <div class="rounded-xl border border-zinc-800 bg-zinc-900/40 p-6">
            <h3 class="mb-3 font-semibold text-zinc-200">{item.q}</h3>
            <p class="text-sm text-zinc-400 leading-relaxed">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="px-6 py-24 text-center">
    <div class="mx-auto max-w-4xl rounded-3xl bg-gradient-to-br from-cyan-400/20 to-violet-400/20 p-12 md:p-24 border border-zinc-800" data-animation="scale">
      <h2 class="mb-6 text-3xl font-bold md:text-5xl tracking-tight">Ready to fix your leaky bucket?</h2>
      <p class="mx-auto mb-10 max-w-xl text-lg text-zinc-300">
        Talk to our senior partners about your growth goals. No account managers, just two partners on every call.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/contact"
          class="rounded-lg bg-cyan-400 px-8 py-4 font-semibold text-zinc-950 transition-colors hover:bg-cyan-300"
        >
          Discuss a CRO Program
        </a>
        <a
          href="mailto:hola@ai-native.es"
          class="rounded-lg border border-zinc-700 bg-zinc-950 px-8 py-4 text-zinc-300 transition-colors hover:border-cyan-400/50"
        >
          Email Us Directly
        </a>
      </div>
    </div>
  </section>
</Layout>

<style>
  @keyframes loading {
    0% { transform: translateX(-100%); }
    100% { transform: translateX(100%); }
  }
</style>
