---
import Layout from '../../layouts/Layout.astro';
import { ChevronRight } from '../../components/FeatherIcons.ts';
---

<Layout
  title="Digital Photoshoots & Video Generation | AI‑Native.es"
  description="Strategic visual storytelling and high-end production for brands that need to simplify complexity. From campaign films to AI-accelerated content systems."
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden px-6 pb-32 pt-24 md:pt-32">
    <div class="absolute inset-0 -z-10 opacity-20">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-cyan-500/20 rounded-full blur-3xl animate-pulse" />
      <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-violet-500/20 rounded-full blur-3xl animate-pulse" style="animation-delay: 1s" />
    </div>

    <div class="mx-auto max-w-5xl text-center" data-animation="fade-up">
      <p class="mb-4 text-xs font-semibold uppercase tracking-[0.3em] text-cyan-300">
        High-End Visual Production
      </p>
      <h1 class="mb-6 text-4xl font-bold tracking-tight md:text-6xl lg:text-7xl">
        Stop shipping generic content. <span class="bg-gradient-to-r from-cyan-300 to-violet-400 bg-clip-text text-transparent">Start telling stories.</span>
      </h1>
      <p class="mx-auto mb-10 max-w-3xl text-lg text-zinc-400 md:text-xl">
        Most visual content lacks direction. We act as your extended marketing team, translating technical complexity 
        into clear, engaging visual systems that live across every channel.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/contact"
          class="rounded-lg bg-cyan-400 px-8 py-4 font-semibold text-zinc-950 transition-colors hover:bg-cyan-300"
        >
          Book a Production Call
        </a>
        <a
          href="#process"
          class="rounded-lg border border-zinc-700 px-8 py-4 text-zinc-300 transition-colors hover:border-cyan-400/50 hover:text-cyan-300"
        >
          Explore Our Process
        </a>
      </div>
    </div>
  </section>

  <!-- Value Proposition -->
  <section class="border-y border-zinc-900 bg-zinc-950/50 px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="grid gap-12 lg:grid-cols-2 items-center">
        <div data-animation="fade-up">
          <h2 class="mb-6 text-3xl font-bold md:text-4xl">Visual storytelling for a complex world</h2>
          <p class="mb-6 text-zinc-400">
            Inspired by studios like Visionary Berlin, we don't just "take photos". We build visual identities 
            that make your product's value obvious. Whether it's a technical B2B solution or a premium 
            consumer brand, we find the visual hook that connects.
          </p>
          <ul class="space-y-4">
            {[
              "Strategic alignment with your brand positioning",
              "Multi-channel asset systems (Web, Social, Print)",
              "Fast-turnaround production cycles",
              "Hybrid model: Craftsmanship + AI acceleration"
            ].map(item => (
              <li class="flex items-center gap-3 text-zinc-300">
                <span class="flex h-5 w-5 items-center justify-center rounded-full bg-cyan-400/20 text-cyan-400 text-xs">✓</span>
                {item}
              </li>
            ))}
          </ul>
        </div>
        <div class="relative rounded-2xl border border-zinc-800 bg-zinc-900/40 p-8 lg:p-12" data-animation="scale">
          <div class="absolute -top-4 -right-4 h-24 w-24 rounded-full bg-violet-500/10 blur-2xl" />
          <div class="space-y-6 text-center">
             <div class="flex justify-center gap-2">
                <div class="h-2 w-8 rounded-full bg-cyan-400"></div>
                <div class="h-2 w-8 rounded-full bg-zinc-800"></div>
                <div class="h-2 w-8 rounded-full bg-zinc-800"></div>
             </div>
             <p class="text-xl font-medium text-zinc-200">"They didn't just deliver a video; they delivered a visual strategy that redefined our social presence."</p>
             <div class="pt-4 border-t border-zinc-800">
                <p class="text-xs font-bold uppercase tracking-widest text-cyan-300">Creative Lead</p>
                <p class="text-[10px] text-zinc-500">European Scale-up</p>
             </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Methodology Section -->
  <section id="process" class="px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16 text-center" data-animation="fade-up">
        <h2 class="mb-4 text-3xl font-bold md:text-5xl">The Production Loop</h2>
        <p class="mx-auto max-w-2xl text-zinc-400">
          We combine traditional creative direction with modern technical tools to ship high-impact 
          visuals at the speed of digital commerce.
        </p>
      </div>

      <div class="grid gap-8 md:grid-cols-2 lg:grid-cols-4">
        {[
          {
            step: "01",
            title: "Strategy",
            desc: "We dive into your product logic to identify the key visual messages that drive trust.",
            icon: "🧠"
          },
          {
            step: "02",
            title: "Concept",
            desc: "Storyboards, moodboards, and shot lists designed for cross-channel consistency.",
            icon: "🎨"
          },
          {
            step: "03",
            title: "Production",
            desc: "On-set or digital-first creation using high-end cinema and photography equipment.",
            icon: "🎬"
          },
          {
            step: "04",
            title: "Iteration",
            desc: "AI-assisted variant generation and scaling to ensure every format is optimized.",
            icon: "🔄"
          }
        ].map(item => (
          <div class="group relative rounded-2xl border border-zinc-800 bg-zinc-900/30 p-8 transition-colors hover:border-cyan-400/40" data-animation="fade-up">
            <span class="absolute top-4 right-6 text-4xl font-black text-zinc-800/50 transition-colors group-hover:text-cyan-400/10">{item.step}</span>
            <div class="mb-6 text-3xl">{item.icon}</div>
            <h3 class="mb-3 text-xl font-semibold">{item.title}</h3>
            <p class="text-sm text-zinc-400 leading-relaxed">{item.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Creative Middle Section: The Content Engine -->
  <section class="bg-gradient-to-b from-zinc-950 to-zinc-900 px-6 py-24 overflow-hidden">
    <div class="mx-auto max-w-6xl">
      <div class="rounded-3xl border border-violet-400/20 bg-violet-950/5 p-8 md:p-16 lg:flex items-center gap-16" data-animation="fade-up">
        <div class="lg:w-1/2">
          <div class="mb-6 inline-flex rounded-full bg-violet-400/10 px-4 py-1 text-xs font-semibold text-violet-300">
            The Content Engine
          </div>
          <h2 class="mb-6 text-3xl font-bold md:text-4xl">Human Craft. AI Speed.</h2>
          <p class="mb-8 text-zinc-400">
            Visual production shouldn't be a bottleneck. We use AI to remove the grunt work—background 
            replacement, asset localization, and lighting adjustments—so our creative team can focus on 
            what matters: the story and the impact.
          </p>
          <div class="space-y-4">
            <div class="flex items-start gap-4">
              <div class="h-1 w-12 mt-3 bg-violet-400 shrink-0"></div>
              <p class="text-sm text-zinc-300"><strong class="text-zinc-100">AI Concepting:</strong> Rapid pre-viz to align on direction before a single shutter clicks.</p>
            </div>
            <div class="flex items-start gap-4">
              <div class="h-1 w-12 mt-3 bg-violet-400 shrink-0"></div>
              <p class="text-sm text-zinc-300"><strong class="text-zinc-100">Smart Scaling:</strong> Turn one hero film into 50+ social variants in days, not weeks.</p>
            </div>
          </div>
        </div>
        <div class="mt-12 lg:mt-0 lg:w-1/2 grid grid-cols-2 gap-4">
           <div class="aspect-[4/5] rounded-xl bg-zinc-900 border border-zinc-800 overflow-hidden relative group">
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent flex items-end p-4">
                 <p class="text-[10px] font-mono text-cyan-300">GEN_01 // PRODUCT_MESH</p>
              </div>
           </div>
           <div class="aspect-[4/5] rounded-xl bg-zinc-800 border border-zinc-700 overflow-hidden relative mt-8">
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent flex items-end p-4">
                 <p class="text-[10px] font-mono text-violet-300">POST_PRO // LIGHT_VAR</p>
              </div>
           </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Service Focus Areas -->
  <section class="px-6 py-24">
    <div class="mx-auto max-w-6xl">
      <div class="mb-16" data-animation="fade-up">
        <h2 class="mb-4 text-3xl font-bold">Production Capabilities</h2>
        <p class="text-zinc-400">Everything you need to build a modern visual brand system.</p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        {[
          {
            title: "Brand & Image Films",
            desc: "High-end cinematic films that capture your brand's essence and mission.",
            icon: "🎥"
          },
          {
            title: "Product Photography",
            desc: "Technical and lifestyle imagery designed to move products on web and print.",
            icon: "📸"
          },
          {
            title: "Social-First Content",
            desc: "Short-form vertical video and motion loops optimized for engagement.",
            icon: "📱"
          },
          {
            title: "Professional Livestreams",
            desc: "Agency-grade livestream production for events, product launches, and panels.",
            icon: "📡"
          }
        ].map(service => (
          <div class="flex gap-6 rounded-2xl border border-zinc-800 bg-zinc-900/20 p-8 transition-colors hover:bg-zinc-900/40" data-animation="fade-up">
            <div class="text-3xl shrink-0">{service.icon}</div>
            <div>
              <h3 class="mb-2 text-xl font-semibold">{service.title}</h3>
              <p class="text-sm text-zinc-400">{service.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="border-t border-zinc-900 px-6 py-24">
    <div class="mx-auto max-w-3xl">
      <h2 class="mb-12 text-center text-3xl font-bold md:text-4xl" data-animation="fade-up">Production FAQ</h2>
      <div class="space-y-6" data-animation="fade-up">
        {[
          {
            q: "Do you handle the full production or just direction?",
            a: "We do both. We can act as your creative lead, managing external crews, or handle full-cycle production through our in-house team and trusted partner network."
          },
          {
            q: "How do you use AI in your video process?",
            a: "We use it for pre-visualization (to show you the look before we shoot), background generation, and rapid format scaling. We never use AI as a replacement for high-fidelity brand photography."
          },
          {
            q: "Can you produce content for technical or niche industries?",
            a: "Yes. Our team specializes in translating complex topics—from SaaS infrastructure to political communication—into clear visual stories."
          },
          {
            q: "What is your typical turnaround time?",
            a: "Content sprints usually take 2-4 weeks from concept to final assets. Larger brand films or full visual system updates typically run in 6-8 week cycles."
          }
        ].map(item => (
          <div class="rounded-xl border border-zinc-800 bg-zinc-900/40 p-6">
            <h3 class="mb-3 font-semibold text-zinc-200">{item.q}</h3>
            <p class="text-sm text-zinc-400 leading-relaxed">{item.a}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="px-6 py-24 text-center">
    <div class="mx-auto max-w-4xl rounded-3xl bg-gradient-to-br from-cyan-400/20 to-violet-400/20 p-12 md:p-24 border border-zinc-800" data-animation="scale">
      <h2 class="mb-6 text-3xl font-bold md:text-5xl tracking-tight">Ready to visualize your story?</h2>
      <p class="mx-auto mb-10 max-w-xl text-lg text-zinc-300">
        Talk to our senior partners about your content needs. We’ll propose a realistic roadmap, not a moodboard.
      </p>
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="/contact"
          class="rounded-lg bg-cyan-400 px-8 py-4 font-semibold text-zinc-950 transition-colors hover:bg-cyan-300"
        >
          Book a Project Call
        </a>
        <a
          href="mailto:hola@ai-native.es"
          class="rounded-lg border border-zinc-700 bg-zinc-950 px-8 py-4 text-zinc-300 transition-colors hover:border-cyan-400/50"
        >
          Email Us Directly
        </a>
      </div>
    </div>
  </section>
</Layout>
