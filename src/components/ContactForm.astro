---
const formspreeId = import.meta.env.PUBLIC_FORMSPREE_ID || 'YOUR_FORM_ID';
---

<form
  action={`https://formspree.io/f/${formspreeId}`}
  method="POST"
  class="space-y-6"
>
  <div>
    <label for="name" class="block text-sm font-medium text-zinc-300 mb-2">Name</label>
    <input
      type="text"
      id="name"
      name="name"
      required
      class="w-full px-4 py-3 bg-zinc-900 border border-zinc-700 rounded-lg focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 outline-none transition-colors"
      placeholder="Your name"
    />
  </div>
  <div>
    <label for="email" class="block text-sm font-medium text-zinc-300 mb-2">Email</label>
    <input
      type="email"
      id="email"
      name="email"
      required
      class="w-full px-4 py-3 bg-zinc-900 border border-zinc-700 rounded-lg focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 outline-none transition-colors"
      placeholder="you@example.com"
    />
  </div>
  <div>
    <label for="message" class="block text-sm font-medium text-zinc-300 mb-2">Message</label>
    <textarea
      id="message"
      name="message"
      required
      rows="5"
      class="w-full px-4 py-3 bg-zinc-900 border border-zinc-700 rounded-lg focus:border-cyan-500 focus:ring-1 focus:ring-cyan-500 outline-none transition-colors resize-none"
      placeholder="Tell us about your project..."
    />
  </div>
  <button
    type="submit"
    class="w-full py-4 bg-cyan-500 hover:bg-cyan-400 text-zinc-950 font-semibold rounded-lg transition-colors"
  >
    Send Message
  </button>
</form>
